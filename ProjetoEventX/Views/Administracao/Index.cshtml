@{
    ViewData["Title"] = "Dashboard - Administração";
    var evento = ViewBag.Evento as ProjetoEventX.Models.Evento;
    var despesas = ViewBag.Despesas as IEnumerable<ProjetoEventX.Models.Despesa>;
    var ptBR = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
    var totalGasto = (decimal)(ViewBag.TotalGasto ?? 0m);
    var totalPedidos = (decimal)(ViewBag.TotalPedidos ?? 0m);
    var totalGeral = (decimal)(ViewBag.TotalGeral ?? 0m);

    // Analíticos
    var catLabels = ViewBag.CategoriasLabels as List<string> ?? new List<string>();
    var catValores = ViewBag.CategoriasValores as List<decimal> ?? new List<decimal>();
    var evoLabels = ViewBag.EvolucaoLabels as List<string> ?? new List<string>();
    var evoValores = ViewBag.EvolucaoValores as List<decimal> ?? new List<decimal>();
    var totalConvidados = (int)(ViewBag.TotalConvidados ?? 0);
    var confirmados = (int)(ViewBag.ConvidadosConfirmados ?? 0);
    var pendentesConv = (int)(ViewBag.ConvidadosPendentes ?? 0);
    var recusados = (int)(ViewBag.ConvidadosRecusados ?? 0);
    var pedAprovados = (int)(ViewBag.PedidosAprovados ?? 0);
    var pedPendentes = (int)(ViewBag.PedidosPendentes ?? 0);
    var pedCancelados = (int)(ViewBag.PedidosCancelados ?? 0);
    var totalPedCount = (int)(ViewBag.TotalPedidosCount ?? 0);
    var pctConfirmados = totalConvidados > 0 ? (int)Math.Round((double)confirmados / totalConvidados * 100) : 0;
}

<style>
    .admin-wrapper {
        background: #f5f1ed;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

    .admin-header {
        background: linear-gradient(135deg, #8B0000 0%, #B22222 40%, #D4A574 100%);
        color: #fff;
        padding: 2.5rem 0;
        margin-bottom: 2rem;
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .admin-header p {
        opacity: 0.85;
        font-size: 1rem;
        margin: 0;
    }

    .admin-header .header-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-right: 1rem;
    }

    .resumo-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
    }

    .resumo-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .resumo-card .card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .card-icon.despesas { background: linear-gradient(135deg, #E65100, #FF8F00); }
    .card-icon.pedidos { background: linear-gradient(135deg, #1565C0, #42A5F5); }
    .card-icon.total { background: linear-gradient(135deg, #8B0000, #B22222); }

    .resumo-card .valor {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
        line-height: 1.1;
    }

    /* Cards analíticos */
    .analytics-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        height: 100%;
    }
    .analytics-card h6 { font-weight: 700; color: #333; margin-bottom: 1rem; font-size: 0.95rem; }
    .analytics-stat {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.6rem 0; border-bottom: 1px solid #f5f2ef;
    }
    .analytics-stat:last-child { border-bottom: none; }
    .analytics-stat .stat-dot {
        width: 10px; height: 10px; border-radius: 50%; margin-right: 8px; flex-shrink: 0;
    }
    .analytics-stat .stat-name { font-weight: 500; color: #555; font-size: 0.88rem; flex: 1; }
    .analytics-stat .stat-num { font-weight: 700; font-size: 1rem; }
    .analytics-progress-bar { height: 8px; border-radius: 4px; background: #f0ece8; overflow: hidden; margin-top: 0.8rem; }
    .analytics-progress-fill { height: 100%; border-radius: 4px; transition: width 0.5s; }
    .analytics-pct { text-align: right; font-size: 0.75rem; color: #888; margin-top: 4px; }
    .chart-card {
        background: #fff; border-radius: 16px; padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 1.5rem;
    }
    .chart-card h6 { font-weight: 700; color: #333; margin-bottom: 1rem; font-size: 0.95rem; }

    .resumo-card .label {
        font-size: 0.85rem;
        color: #888;
        margin-top: 2px;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .form-card h5 {
        color: #8B0000;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .form-card .form-label {
        font-weight: 600;
        color: #555;
        font-size: 0.9rem;
    }

    .form-card .form-control {
        border-radius: 10px;
        border: 2px solid #e0e0e0;
        padding: 10px 14px;
        transition: border-color 0.3s;
    }

    .form-card .form-control:focus {
        border-color: #8B0000;
        box-shadow: 0 0 0 3px rgba(139, 0, 0, 0.1);
    }

    .btn-adicionar {
        background: linear-gradient(135deg, #8B0000, #B22222);
        color: #fff;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s;
    }

    .btn-adicionar:hover {
        background: linear-gradient(135deg, #6B0000, #8B0000);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(139, 0, 0, 0.3);
        color: #fff;
    }

    .input-valor-wrapper {
        position: relative;
    }

    .input-valor-wrapper .prefixo {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-weight: 700;
        color: #8B0000;
        font-size: 1rem;
        pointer-events: none;
    }

    .input-valor-wrapper input {
        padding-left: 48px !important;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .despesas-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .despesas-card h5 {
        font-weight: 700;
        color: #333;
        margin-bottom: 1.2rem;
    }

    .despesa-item {
        display: flex;
        align-items: center;
        padding: 1rem;
        border-radius: 12px;
        background: #f8f9fa;
        margin-bottom: 0.6rem;
        transition: background 0.2s;
    }

    .despesa-item:hover {
        background: #f0ebe5;
    }

    .despesa-item .despesa-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, #E65100, #FF8F00);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1rem;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    .despesa-item .despesa-info { flex: 1; }
    .despesa-item .despesa-desc { font-weight: 600; color: #333; font-size: 0.95rem; }
    .despesa-item .despesa-data { font-size: 0.8rem; color: #999; }
    .despesa-item .despesa-valor { font-weight: 700; color: #8B0000; font-size: 1rem; white-space: nowrap; margin-right: 8px; }

    .despesa-acoes {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .btn-desp-acao {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-desp-editar {
        background: #E3F2FD;
        color: #1565C0;
    }

    .btn-desp-editar:hover {
        background: #1565C0;
        color: #fff;
    }

    .btn-desp-excluir {
        background: #FFEBEE;
        color: #C62828;
    }

    .btn-desp-excluir:hover {
        background: #C62828;
        color: #fff;
    }

    .modal-edit-desp .modal-header {
        background: #1565C0;
        color: #fff;
    }

    .modal-delete-desp .modal-header {
        background: #C62828;
        color: #fff;
    }

    .acoes-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .acoes-card h5 {
        font-weight: 700;
        color: #333;
        margin-bottom: 1.2rem;
    }

    .acao-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 1rem;
        border-radius: 12px;
        background: #f8f9fa;
        margin-bottom: 0.6rem;
        text-decoration: none;
        color: #333;
        transition: all 0.2s;
        font-weight: 600;
    }

    .acao-link:hover {
        background: #f0ebe5;
        transform: translateX(5px);
        color: #8B0000;
    }

    .acao-link .acao-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .acao-icon.relatorio { background: linear-gradient(135deg, #1565C0, #42A5F5); }
    .acao-icon.voltar { background: linear-gradient(135deg, #8B0000, #D4A574); }
    .acao-icon.pedidos-icon { background: linear-gradient(135deg, #2E7D32, #43A047); }

    .empty-despesas {
        text-align: center;
        padding: 2rem;
        color: #999;
    }

    .empty-despesas i {
        font-size: 2.5rem;
        opacity: 0.3;
        margin-bottom: 0.8rem;
    }

    .alert-sucesso-admin {
        background: #E8F5E9;
        border: 1px solid #A5D6A7;
        color: #2E7D32;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }
</style>

<div class="admin-wrapper">
    <section class="admin-header">
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="header-icon">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <div>
                    <h1>Administração — @(evento?.NomeEvento ?? "Evento")</h1>
                    <p>Controle financeiro e gestão de despesas do evento</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert-sucesso-admin">
                <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
            </div>
        }

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="resumo-card">
                    <div class="card-icon despesas"><i class="fas fa-file-invoice-dollar"></i></div>
                    <div class="valor">R$ @totalGasto.ToString("N2", ptBR)</div>
                    <div class="label">Total em Despesas</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="resumo-card">
                    <div class="card-icon pedidos"><i class="fas fa-shopping-cart"></i></div>
                    <div class="valor">R$ @totalPedidos.ToString("N2", ptBR)</div>
                    <div class="label">Total em Pedidos</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="resumo-card">
                    <div class="card-icon total"><i class="fas fa-coins"></i></div>
                    <div class="valor" style="color: #8B0000;">R$ @totalGeral.ToString("N2", ptBR)</div>
                    <div class="label">Total Geral</div>
                </div>
            </div>
        </div>

        <!-- Cards Analíticos: Convidados, Pedidos, Gráficos -->
        <div class="row g-3 mb-4">
            <!-- Card Convidados -->
            <div class="col-md-3">
                <div class="analytics-card">
                    <h6><i class="fas fa-user-friends me-2" style="color: #7B1FA2;"></i>Convidados</h6>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #7B1FA2;"></div>
                            <span class="stat-name">Total</span>
                        </div>
                        <span class="stat-num" style="color: #7B1FA2;">@totalConvidados</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #2E7D32;"></div>
                            <span class="stat-name">Confirmados</span>
                        </div>
                        <span class="stat-num" style="color: #2E7D32;">@confirmados</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #E65100;"></div>
                            <span class="stat-name">Pendentes</span>
                        </div>
                        <span class="stat-num" style="color: #E65100;">@pendentesConv</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #C62828;"></div>
                            <span class="stat-name">Recusados</span>
                        </div>
                        <span class="stat-num" style="color: #C62828;">@recusados</span>
                    </div>
                    <div class="analytics-progress-bar">
                        <div class="analytics-progress-fill" style="width: @(pctConfirmados)%; background: linear-gradient(135deg, #2E7D32, #66BB6A);"></div>
                    </div>
                    <div class="analytics-pct">@(pctConfirmados)% confirmados</div>
                </div>
            </div>

            <!-- Card Pedidos -->
            <div class="col-md-3">
                <div class="analytics-card">
                    <h6><i class="fas fa-shopping-bag me-2" style="color: #1565C0;"></i>Pedidos</h6>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #1565C0;"></div>
                            <span class="stat-name">Total</span>
                        </div>
                        <span class="stat-num" style="color: #1565C0;">@totalPedCount</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #2E7D32;"></div>
                            <span class="stat-name">Aprovados</span>
                        </div>
                        <span class="stat-num" style="color: #2E7D32;">@pedAprovados</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #E65100;"></div>
                            <span class="stat-name">Pendentes</span>
                        </div>
                        <span class="stat-num" style="color: #E65100;">@pedPendentes</span>
                    </div>
                    <div class="analytics-stat">
                        <div class="d-flex align-items-center">
                            <div class="stat-dot" style="background: #C62828;"></div>
                            <span class="stat-name">Cancelados</span>
                        </div>
                        <span class="stat-num" style="color: #C62828;">@pedCancelados</span>
                    </div>
                    @{
                        var pctPedAprov = totalPedCount > 0 ? (int)Math.Round((double)pedAprovados / totalPedCount * 100) : 0;
                    }
                    <div class="analytics-progress-bar">
                        <div class="analytics-progress-fill" style="width: @(pctPedAprov)%; background: linear-gradient(135deg, #1565C0, #42A5F5);"></div>
                    </div>
                    <div class="analytics-pct">@(pctPedAprov)% aprovados</div>
                </div>
            </div>

            <!-- Gráfico Presença (Doughnut) -->
            <div class="col-md-3">
                <div class="chart-card" style="height: 100%;">
                    <h6><i class="fas fa-chart-pie me-2" style="color: #2E7D32;"></i>Presença</h6>
                    @if (totalConvidados > 0)
                    {
                        <canvas id="presencaChart" height="200"></canvas>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 2rem 0; color: #bbb;">
                            <i class="fas fa-users" style="font-size: 2rem; opacity: 0.3;"></i>
                            <p style="margin-top: 0.5rem; font-size: 0.85rem;">Sem convidados ainda</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Gráfico Distribuição Gastos (Doughnut) -->
            <div class="col-md-3">
                <div class="chart-card" style="height: 100%;">
                    <h6><i class="fas fa-chart-doughnut me-2" style="color: #E65100;"></i>Gastos por Categoria</h6>
                    @if (catLabels.Any())
                    {
                        <canvas id="categoriasChart" height="200"></canvas>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 2rem 0; color: #bbb;">
                            <i class="fas fa-receipt" style="font-size: 2rem; opacity: 0.3;"></i>
                            <p style="margin-top: 0.5rem; font-size: 0.85rem;">Sem despesas ainda</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Gráfico Evolução de Despesas -->
        @if (evoLabels.Any())
        {
            <div class="chart-card mb-4">
                <h6><i class="fas fa-chart-line me-2" style="color: #1565C0;"></i>Evolução das Despesas ao Longo do Tempo</h6>
                <canvas id="evolucaoChart" height="80"></canvas>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="form-card mb-4">
                    <h5><i class="fas fa-plus-circle me-2"></i>Adicionar Despesa</h5>
                    <form asp-action="AdicionarDespesa" method="post" id="formDespesa">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventoId" value="@evento?.Id" />
                        <div class="row">
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label class="form-label"><i class="fas fa-tag me-1 text-muted"></i> Descrição</label>
                                    <input type="text" name="Descricao" class="form-control" placeholder="Ex: Aluguel do espaço, Decoração..." required />
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="mb-3">
                                    <label class="form-label"><i class="fas fa-dollar-sign me-1 text-muted"></i> Valor</label>
                                    <div class="input-valor-wrapper">
                                        <span class="prefixo">R$</span>
                                        <input type="text" name="Valor" id="valorDespesa" class="form-control" placeholder="0,00" inputmode="decimal" required />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn-adicionar">
                                <i class="fas fa-plus me-2"></i>Adicionar Despesa
                            </button>
                        </div>
                    </form>
                </div>

                <div class="despesas-card">
                    <h5><i class="fas fa-history me-2"></i>Histórico de Despesas</h5>
                    @if (despesas != null && despesas.Any())
                    {
                        @foreach (var despesa in despesas)
                        {
                            <div class="despesa-item">
                                <div class="despesa-icon">
                                    @if (!string.IsNullOrEmpty(despesa.Origem))
                                    {
                                        <i class="fas fa-shopping-cart"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-receipt"></i>
                                    }
                                </div>
                                <div class="despesa-info">
                                    <div class="despesa-desc">
                                        @despesa.Descricao
                                        @if (!string.IsNullOrEmpty(despesa.Origem))
                                        {
                                            <span class="badge bg-info text-white ms-1" style="font-size: 0.7rem; font-weight: 500;">@despesa.Origem</span>
                                        }
                                    </div>
                                    <div class="despesa-data">@despesa.DataDespesa.ToString("dd/MM/yyyy 'às' HH:mm")</div>
                                </div>
                                <div class="despesa-valor">R$ @despesa.Valor.ToString("N2", ptBR)</div>
                                @if (string.IsNullOrEmpty(despesa.Origem))
                                {
                                <div class="despesa-acoes">
                                    <button class="btn-desp-acao btn-desp-editar" title="Editar" data-bs-toggle="modal" data-bs-target="#editDesp-@despesa.Id">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <button class="btn-desp-acao btn-desp-excluir" title="Excluir" data-bs-toggle="modal" data-bs-target="#deleteDesp-@despesa.Id">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-despesas">
                            <i class="fas fa-receipt d-block"></i>
                            <p class="mb-0">Nenhuma despesa registrada ainda.</p>
                            <small>Adicione despesas usando o formulário acima.</small>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="acoes-card">
                    <h5><i class="fas fa-bolt me-2"></i>Ações</h5>

                    <a asp-action="RelatorioGastos" asp-route-eventoId="@evento?.Id" class="acao-link">
                        <div class="acao-icon relatorio"><i class="fas fa-chart-bar"></i></div>
                        <div>
                            <div>Relatório de Gastos</div>
                            <small style="color: #999; font-weight: 400;">Visualizar relatório completo</small>
                        </div>
                    </a>

                    <a asp-controller="Pedido" asp-action="Index" asp-route-eventoId="@evento?.Id" class="acao-link">
                        <div class="acao-icon pedidos-icon"><i class="fas fa-shopping-bag"></i></div>
                        <div>
                            <div>Ver Pedidos</div>
                            <small style="color: #999; font-weight: 400;">Pedidos deste evento</small>
                        </div>
                    </a>

                    <a asp-controller="Organizador" asp-action="DetalhesEvento" asp-route-id="@evento?.Id" class="acao-link">
                        <div class="acao-icon voltar"><i class="fas fa-arrow-left"></i></div>
                        <div>
                            <div>Voltar ao Evento</div>
                            <small style="color: #999; font-weight: 400;">Detalhes de @(evento?.NomeEvento ?? "Evento")</small>
                        </div>
                    </a>
                </div>

                <div class="acoes-card mt-4">
                    <h5><i class="fas fa-info-circle me-2"></i>Resumo</h5>
                    <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid #f0f0f0;">
                        <span style="color: #888;">Despesas</span>
                        <span style="font-weight: 600;">@(despesas?.Count() ?? 0) registro(s)</span>
                    </div>
                    <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid #f0f0f0;">
                        <span style="color: #888;">Valor Despesas</span>
                        <span style="font-weight: 600; color: #E65100;">R$ @totalGasto.ToString("N2", ptBR)</span>
                    </div>
                    <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid #f0f0f0;">
                        <span style="color: #888;">Valor Pedidos</span>
                        <span style="font-weight: 600; color: #1565C0;">R$ @totalPedidos.ToString("N2", ptBR)</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span style="font-weight: 700; color: #333;">Total Geral</span>
                        <span style="font-weight: 700; color: #8B0000; font-size: 1.1rem;">R$ @totalGeral.ToString("N2", ptBR)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (despesas != null && despesas.Any())
{
    @foreach (var despesa in despesas)
    {
        <!-- Modal Editar Despesa -->
        <div class="modal fade modal-edit-desp" id="editDesp-@despesa.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-pen me-2"></i>Editar Despesa</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form asp-action="EditarDespesa" method="post" class="form-edit-despesa">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="despesaId" value="@despesa.Id" />
                            <input type="hidden" name="eventoId" value="@evento?.Id" />
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <input type="text" name="Descricao" class="form-control" value="@despesa.Descricao" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Valor (R$)</label>
                                <div class="input-valor-wrapper">
                                    <span class="prefixo">R$</span>
                                    <input type="text" name="Valor" class="form-control input-valor-edit" value="@despesa.Valor.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))" inputmode="decimal" required />
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2">
                                <button type="button" class="btn" style="background: #e0e0e0; color: #333; font-weight: 600; border-radius: 8px;" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn" style="background: #1565C0; color: #fff; font-weight: 600; border-radius: 8px;">
                                    <i class="fas fa-save me-1"></i>Salvar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Excluir Despesa -->
        <div class="modal fade modal-delete-desp" id="deleteDesp-@despesa.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-trash me-2"></i>Excluir Despesa</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; color: #E65100; margin-bottom: 1rem;"></i>
                        <p style="font-weight: 600; color: #333;">Tem certeza que deseja excluir?</p>
                        <p style="font-size: 1.1rem; font-weight: 700; color: #8B0000;">@despesa.Descricao</p>
                        <p style="font-size: 0.9rem; color: #666;">R$ @despesa.Valor.ToString("N2", ptBR)</p>
                        <p style="font-size: 0.8rem; color: #999;">Esta ação não pode ser desfeita.</p>
                    </div>
                    <div class="modal-footer justify-content-center" style="border: none;">
                        <button type="button" class="btn" style="background: #e0e0e0; color: #333; font-weight: 600; border-radius: 8px;" data-bs-dismiss="modal">Cancelar</button>
                        <form asp-action="ExcluirDespesa" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="despesaId" value="@despesa.Id" />
                            <input type="hidden" name="eventoId" value="@evento?.Id" />
                            <button type="submit" class="btn" style="background: #C62828; color: #fff; font-weight: 600; border-radius: 8px;">
                                <i class="fas fa-trash me-1"></i>Excluir
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var valorInput = document.getElementById('valorDespesa');

        // Máscara de moeda brasileira (formato: 1.234,56)
        function aplicarMascaraMoeda(input) {
            input.addEventListener('input', function () {
                var valor = this.value.replace(/[^0-9]/g, '');
                if (valor === '') { this.value = ''; return; }
                valor = (parseInt(valor, 10) / 100).toFixed(2);
                valor = valor.replace('.', ',');
                valor = valor.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
                this.value = valor;
            });
        }

        aplicarMascaraMoeda(valorInput);

        // Aplicar máscara nos inputs de edição também
        document.querySelectorAll('.input-valor-edit').forEach(function (input) {
            aplicarMascaraMoeda(input);
        });
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Gráfico de Presença (Doughnut)
        var presencaEl = document.getElementById('presencaChart');
        if (presencaEl) {
            new Chart(presencaEl.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Confirmados', 'Pendentes', 'Recusados'],
                    datasets: [{
                        data: [@confirmados, @pendentesConv, @recusados],
                        backgroundColor: ['#2E7D32', '#E65100', '#C62828'],
                        borderWidth: 2, borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 10, font: { size: 11 } } }
                    }
                }
            });
        }

        // Gráfico de Categorias de Gastos (Doughnut)
        var catEl = document.getElementById('categoriasChart');
        if (catEl) {
            new Chart(catEl.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(string.Join(",", catLabels.Select(l => $"'{l}'")))],
                    datasets: [{
                        data: [@Html.Raw(string.Join(",", catValores.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture))))],
                        backgroundColor: ['#E65100', '#7B1FA2', '#1565C0', '#2E7D32', '#546E7A'],
                        borderWidth: 2, borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 10, font: { size: 11 } } },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    return ctx.label + ': R$ ' + ctx.parsed.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                                }
                            }
                        }
                    }
                }
            });
        }

        // Gráfico de Evolução de Despesas (Line)
        var evoEl = document.getElementById('evolucaoChart');
        if (evoEl) {
            new Chart(evoEl.getContext('2d'), {
                type: 'line',
                data: {
                    labels: [@Html.Raw(string.Join(",", evoLabels.Select(l => $"'{l}'")))],
                    datasets: [{
                        label: 'Despesas (R$)',
                        data: [@Html.Raw(string.Join(",", evoValores.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture))))],
                        borderColor: '#8B0000',
                        backgroundColor: 'rgba(139, 0, 0, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#8B0000',
                        pointRadius: 5,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    return 'R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function (val) { return 'R$ ' + val.toLocaleString('pt-BR'); }
                            },
                            grid: { color: 'rgba(0,0,0,0.04)' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    });
</script>

