@model ProjetoEventX.Models.Evento

@{
    ViewData["Title"] = "Editar Evento";
    var ptBR = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
}

<style>
    .edit-wrapper {
        background: #f5f1ed;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

    .edit-header {
        background: linear-gradient(135deg, #8B0000 0%, #B22222 40%, #D4A574 100%);
        color: #fff;
        padding: 2.5rem 0;
        margin-bottom: 2rem;
    }

    .edit-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .edit-header p {
        opacity: 0.85;
        font-size: 1rem;
        margin: 0;
    }

    .edit-header .header-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-right: 1rem;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    .form-card h5 {
        font-weight: 700;
        color: #8B0000;
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
        padding-bottom: 0.8rem;
        border-bottom: 2px solid #f0f0f0;
    }

    .form-card .form-label {
        font-weight: 600;
        color: #444;
        font-size: 0.9rem;
        margin-bottom: 0.4rem;
    }

    .form-card .form-label i {
        color: #8B0000;
        margin-right: 0.3rem;
    }

    .form-card .form-control,
    .form-card .form-select {
        border: 2px solid #e8e4e0;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .form-card .form-control:focus,
    .form-card .form-select:focus {
        border-color: #8B0000;
        box-shadow: 0 0 0 3px rgba(139,0,0,0.1);
    }

    .form-card .form-text {
        font-size: 0.8rem;
        color: #999;
    }

    .form-card textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .input-valor-wrapper {
        position: relative;
    }

    .input-valor-wrapper .prefixo {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-weight: 700;
        color: #8B0000;
        font-size: 0.95rem;
        z-index: 2;
    }

    .input-valor-wrapper input {
        padding-left: 45px;
    }

    .btn-salvar {
        background: linear-gradient(135deg, #8B0000, #B22222);
        color: #fff;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.2s;
    }

    .btn-salvar:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(139,0,0,0.3);
        color: #fff;
    }

    .btn-voltar {
        background: #f0ece8;
        color: #555;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-voltar:hover {
        background: #e5e0db;
        color: #333;
    }

    .btn-detalhes {
        background: #E3F2FD;
        color: #1565C0;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-detalhes:hover {
        background: #BBDEFB;
        color: #0D47A1;
    }

    .alert-sucesso {
        background: #E8F5E9;
        color: #2E7D32;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    .alert-erro {
        background: #FFEBEE;
        color: #C62828;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }
</style>

<div class="edit-wrapper">
    <section class="edit-header">
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="header-icon">
                    <i class="fas fa-edit"></i>
                </div>
                <div>
                    <h1>Editar Evento</h1>
                    <p>Atualize os detalhes de <strong>@Model.NomeEvento</strong></p>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert-erro mb-3">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    </div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert-sucesso mb-3">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                }

                <form asp-action="Edit" id="eventoForm">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="OrganizadorId" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="LocalId" />
                    <div asp-validation-summary="ModelOnly" class="alert-erro mb-3" role="alert"></div>

                    <!-- Informações Básicas -->
                    <div class="form-card">
                        <h5><i class="fas fa-info-circle me-2"></i>Informações Básicas</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NomeEvento" class="form-label">
                                    <i class="fas fa-calendar"></i> Nome do Evento
                                </label>
                                <input asp-for="NomeEvento" class="form-control" placeholder="Digite o nome do evento" />
                                <span asp-validation-for="NomeEvento" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TipoEvento" class="form-label">
                                    <i class="fas fa-tag"></i> Tipo do Evento
                                </label>
                                <select asp-for="TipoEvento" class="form-select">
                                    <option value="">Selecione o tipo</option>
                                    <option value="Casamento">💒 Casamento</option>
                                    <option value="Aniversário">🎂 Aniversário</option>
                                    <option value="Corporativo">🏢 Corporativo</option>
                                    <option value="Festa">🎉 Festa</option>
                                    <option value="Conferência">🎤 Conferência</option>
                                    <option value="Formatura">🎓 Formatura</option>
                                    <option value="Workshop">📚 Workshop</option>
                                    <option value="Outros">📋 Outros</option>
                                </select>
                                <span asp-validation-for="TipoEvento" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DescricaoEvento" class="form-label">
                                <i class="fas fa-align-left"></i> Descrição do Evento
                            </label>
                            <textarea asp-for="DescricaoEvento" class="form-control" rows="4" placeholder="Descreva os detalhes do seu evento..."></textarea>
                            <span asp-validation-for="DescricaoEvento" class="text-danger"></span>
                            <small class="form-text">Forneça detalhes que ajudem no planejamento</small>
                        </div>
                    </div>

                    <!-- Data e Horário -->
                    <div class="form-card">
                        <h5><i class="fas fa-clock me-2"></i>Data e Horário</h5>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="DataEvento" class="form-label">
                                    <i class="fas fa-calendar-day"></i> Data do Evento
                                </label>
                                <input asp-for="DataEvento" type="date" class="form-control" />
                                <span asp-validation-for="DataEvento" class="text-danger"></span>
                                <small class="form-text">A data deve ser futura</small>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="HoraInicio" class="form-label">
                                    <i class="fas fa-play-circle"></i> Hora de Início
                                </label>
                                <input asp-for="HoraInicio" class="form-control hora-input" placeholder="18:00" maxlength="5" />
                                <span asp-validation-for="HoraInicio" class="text-danger"></span>
                                <small class="form-text">Formato: HH:MM (ex: 18:00)</small>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="HoraFim" class="form-label">
                                    <i class="fas fa-stop-circle"></i> Hora de Fim
                                </label>
                                <input asp-for="HoraFim" class="form-control hora-input" placeholder="22:00" maxlength="5" />
                                <span asp-validation-for="HoraFim" class="text-danger"></span>
                                <small class="form-text">Formato: HH:MM (ex: 22:00)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Detalhes e Orçamento -->
                    <div class="form-card">
                        <h5><i class="fas fa-chart-bar me-2"></i>Detalhes e Orçamento</h5>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="StatusEvento" class="form-label">
                                    <i class="fas fa-flag"></i> Status
                                </label>
                                <select asp-for="StatusEvento" class="form-select">
                                    <option value="Planejado">📋 Planejado</option>
                                    <option value="Em Andamento">⚡ Em Andamento</option>
                                    <option value="Concluído">✅ Concluído</option>
                                    <option value="Cancelado">❌ Cancelado</option>
                                </select>
                                <span asp-validation-for="StatusEvento" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="PublicoEstimado" class="form-label">
                                    <i class="fas fa-users"></i> Público Estimado
                                </label>
                                <input asp-for="PublicoEstimado" type="number" class="form-control" placeholder="50" min="1" max="10000" />
                                <span asp-validation-for="PublicoEstimado" class="text-danger"></span>
                                <small class="form-text">Número de pessoas esperadas</small>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="CustoEstimado" class="form-label">
                                    <i class="fas fa-dollar-sign"></i> Custo Estimado
                                </label>
                                <div class="input-valor-wrapper">
                                    <span class="prefixo">R$</span>
                                    <input asp-for="CustoEstimado" class="form-control dinheiro-input" placeholder="0,00" />
                                </div>
                                <span asp-validation-for="CustoEstimado" class="text-danger"></span>
                                <small class="form-text">Orçamento previsto para o evento</small>
                            </div>
                        </div>
                    </div>

                    <!-- Botões de Ação -->
                    <div class="form-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn-voltar">
                                <i class="fas fa-arrow-left me-1"></i> Voltar para a Lista
                            </a>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-detalhes">
                                    <i class="fas fa-eye me-1"></i> Ver Detalhes
                                </a>
                                <button type="submit" class="btn-salvar">
                                    <i class="fas fa-save me-1"></i> Salvar Alterações
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('eventoForm');
            const dataEvento = document.querySelector('input[name="DataEvento"]');
            const horaInicio = document.querySelector('input[name="HoraInicio"]');
            const horaFim = document.querySelector('input[name="HoraFim"]');
            
            // Definir data mínima como hoje
            const hoje = new Date();
            const dataMinima = hoje.toISOString().split('T')[0];
            if (dataEvento) {
                dataEvento.setAttribute('min', dataMinima);
            }

            // Formatação inicial para campos existentes
            if (horaInicio && horaInicio.value && horaInicio.value.length === 4) {
                horaInicio.value = horaInicio.value.substring(0,2) + ':' + horaInicio.value.substring(2);
            }
            if (horaFim && horaFim.value && horaFim.value.length === 4) {
                horaFim.value = horaFim.value.substring(0,2) + ':' + horaFim.value.substring(2);
            }
            
            // Validação no envio do formulário
            form.addEventListener('submit', function(e) {
                let valido = true;
                
                // Validar hora de início
                if (horaInicio && horaInicio.value && !validarHora(horaInicio.value)) {
                    mostrarErro(horaInicio, 'Formato de hora inválido (use HH:MM)');
                    valido = false;
                }
                
                // Validar hora de fim
                if (horaFim && horaFim.value && !validarHora(horaFim.value)) {
                    mostrarErro(horaFim, 'Formato de hora inválido (use HH:MM)');
                    valido = false;
                }
                
                // Validar se hora de fim é maior que hora de início
                if (horaInicio && horaFim && horaInicio.value && horaFim.value) {
                    const [horaIni, minIni] = horaInicio.value.split(':').map(Number);
                    const [horaEnd, minEnd] = horaFim.value.split(':').map(Number);
                    
                    const minutosInicio = horaIni * 60 + minIni;
                    const minutosFim = horaEnd * 60 + minEnd;
                    
                    if (minutosFim <= minutosInicio) {
                        mostrarErro(horaFim, 'Hora de fim deve ser maior que hora de início');
                        valido = false;
                    }
                }
                
                if (!valido) {
                    e.preventDefault();
                }
            });

            function validarHora(valor) {
                const regex = /^([01]\d|2[0-3]):([0-5]\d)$/;
                return regex.test(valor);
            }
            
            function mostrarErro(campo, mensagem) {
                const erroExistente = campo.parentNode.querySelector('.erro-customizado');
                if (erroExistente) {
                    erroExistente.remove();
                }
                
                const spanErro = document.createElement('span');
                spanErro.className = 'text-danger erro-customizado';
                spanErro.style.fontSize = '0.85rem';
                spanErro.textContent = mensagem;
                campo.parentNode.appendChild(spanErro);
                
                campo.classList.add('is-invalid');
                
                campo.addEventListener('input', function() {
                    campo.classList.remove('is-invalid');
                    if (spanErro && spanErro.parentNode) {
                        spanErro.remove();
                    }
                }, { once: true });
            }
        });
    </script>
}
