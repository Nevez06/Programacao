@model ProjetoEventX.Models.Evento

@{
    ViewData["Title"] = "Excluir Evento";
}

<h1>Excluir Evento</h1>

<h3>Tem certeza que deseja excluir este evento?</h3>
<div>
    <h4>Evento</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NomeEvento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NomeEvento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DescricaoEvento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DescricaoEvento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataEvento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataEvento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TipoEvento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TipoEvento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StatusEvento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StatusEvento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Organizador)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrganizadorId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LocalId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LocalId)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2 align-items-center">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Excluir</button>
            <a asp-action="Index" class="btn btn-eventx-secondary"><i class="fas fa-arrow-left"></i> Voltar para a Lista</a>
        </div>
    </form>
</div>
