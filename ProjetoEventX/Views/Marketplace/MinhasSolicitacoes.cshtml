@model IEnumerable<ProjetoEventX.Models.SolicitacaoOrcamento>
@{
    ViewData["Title"] = "Minhas Solicitações de Orçamento";
}

<style>
    .solicitacoes-section {
        background: #f5f0eb;
        min-height: 80vh;
        padding: 2rem 0 3rem;
    }
    .solicitacoes-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
    }
    .solicitacoes-header h2 {
        color: #8B0000;
        font-weight: 700;
        margin: 0;
    }
    .btn-marketplace {
        background: #8B0000;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }
    .btn-marketplace:hover { background: #a00000; color: #fff; }

    .solicitacao-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        padding: 1.5rem;
        margin-bottom: 1rem;
        transition: all 0.3s;
    }
    .solicitacao-card:hover { box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
    .solicitacao-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1rem;
    }
    .solicitacao-titulo { font-weight: 700; font-size: 1.1rem; color: #333; margin-bottom: 0.2rem; }
    .solicitacao-fornecedor { font-size: 0.9rem; color: #8B0000; font-weight: 600; }

    .status-badge {
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .status-pendente { background: #fef3c7; color: #92400e; }
    .status-respondido { background: #dbeafe; color: #1e40af; }
    .status-aceito { background: #d1fae5; color: #065f46; }
    .status-recusado { background: #fee2e2; color: #991b1b; }
    .status-cancelado { background: #f3f4f6; color: #6b7280; }

    .solicitacao-detalhes {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.8rem;
        margin: 1rem 0;
    }
    .detalhe-item {
        font-size: 0.85rem;
        color: #666;
    }
    .detalhe-item i { color: #8B0000; margin-right: 0.3rem; }
    .detalhe-item .valor { font-weight: 600; color: #333; }

    .resposta-box {
        background: #f0f7ff;
        border-radius: 12px;
        padding: 1.2rem;
        margin-top: 1rem;
        border-left: 4px solid #3b82f6;
    }
    .resposta-box h6 { font-weight: 700; color: #1e40af; margin-bottom: 0.5rem; }
    .resposta-box .valor-proposto {
        font-size: 1.3rem;
        font-weight: 800;
        color: #8B0000;
        margin: 0.5rem 0;
    }

    .btn-aceitar {
        background: #059669;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.5rem 1.5rem;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s;
    }
    .btn-aceitar:hover { background: #047857; color: #fff; }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    }
    .empty-state i { font-size: 4rem; color: #ddd; margin-bottom: 1rem; }

    .tab-filtros {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    .tab-filtro {
        padding: 0.4rem 1.2rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 2px solid #e0d6cc;
        color: #666;
        background: #fff;
        text-decoration: none;
    }
    .tab-filtro:hover, .tab-filtro.active { border-color: #8B0000; color: #8B0000; background: #faf5f0; }
</style>

<section class="solicitacoes-section">
    <div class="container">
        <div class="solicitacoes-header">
            <div>
                <h2><i class="fas fa-file-invoice-dollar"></i> Minhas Solicitações</h2>
                <p class="text-muted mb-0">Acompanhe suas solicitações de orçamento enviadas</p>
            </div>
            <a asp-action="Index" class="btn-marketplace">
                <i class="fas fa-store"></i> Marketplace
            </a>
        </div>

        <!-- Filtros rápidos -->
        <div class="tab-filtros">
            <span class="tab-filtro active" onclick="filtrarStatus('')">Todas (@Model.Count())</span>
            <span class="tab-filtro" onclick="filtrarStatus('Pendente')">
                Pendentes (@Model.Count(s => s.Status == "Pendente"))
            </span>
            <span class="tab-filtro" onclick="filtrarStatus('Respondido')">
                Respondidas (@Model.Count(s => s.Status == "Respondido"))
            </span>
            <span class="tab-filtro" onclick="filtrarStatus('Aceito')">
                Aceitas (@Model.Count(s => s.Status == "Aceito"))
            </span>
            <span class="tab-filtro" onclick="filtrarStatus('Recusado')">
                Recusadas (@Model.Count(s => s.Status == "Recusado"))
            </span>
        </div>

        @if (Model.Any())
        {
            @foreach (var solicitacao in Model)
            {
                var statusClass = solicitacao.Status switch
                {
                    "Pendente" => "status-pendente",
                    "Respondido" => "status-respondido",
                    "Aceito" => "status-aceito",
                    "Recusado" => "status-recusado",
                    _ => "status-cancelado"
                };

                <div class="solicitacao-card" data-status="@solicitacao.Status">
                    <div class="solicitacao-card-header">
                        <div>
                            <div class="solicitacao-titulo">@solicitacao.Titulo</div>
                            <div class="solicitacao-fornecedor">
                                <i class="fas fa-store"></i> @solicitacao.Fornecedor?.Pessoa?.Nome
                            </div>
                        </div>
                        <span class="status-badge @statusClass">@solicitacao.Status</span>
                    </div>

                    <p style="font-size: 0.9rem; color: #666;">@solicitacao.Descricao</p>

                    <div class="solicitacao-detalhes">
                        <div class="detalhe-item">
                            <i class="fas fa-calendar"></i> Solicitado em
                            <div class="valor">@solicitacao.DataSolicitacao.ToString("dd/MM/yyyy")</div>
                        </div>
                        @if (solicitacao.DataEvento.HasValue)
                        {
                            <div class="detalhe-item">
                                <i class="fas fa-calendar-alt"></i> Data do evento
                                <div class="valor">@solicitacao.DataEvento.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(solicitacao.LocalEvento))
                        {
                            <div class="detalhe-item">
                                <i class="fas fa-map-marker-alt"></i> Local
                                <div class="valor">@solicitacao.LocalEvento</div>
                            </div>
                        }
                        @if (solicitacao.OrcamentoEstimado.HasValue)
                        {
                            <div class="detalhe-item">
                                <i class="fas fa-wallet"></i> Orçamento estimado
                                <div class="valor">R$ @solicitacao.OrcamentoEstimado.Value.ToString("N2")</div>
                            </div>
                        }
                        @if (solicitacao.QuantidadeConvidados.HasValue)
                        {
                            <div class="detalhe-item">
                                <i class="fas fa-users"></i> Convidados
                                <div class="valor">@solicitacao.QuantidadeConvidados</div>
                            </div>
                        }
                        @if (solicitacao.Evento != null)
                        {
                            <div class="detalhe-item">
                                <i class="fas fa-calendar-check"></i> Evento
                                <div class="valor">@solicitacao.Evento.NomeEvento</div>
                            </div>
                        }
                    </div>

                    @if (solicitacao.Status == "Respondido" && !string.IsNullOrEmpty(solicitacao.RespostaFornecedor))
                    {
                        <div class="resposta-box">
                            <h6><i class="fas fa-reply"></i> Resposta do Fornecedor</h6>
                            <p style="font-size: 0.9rem; color: #555; margin-bottom: 0.5rem;">@solicitacao.RespostaFornecedor</p>
                            @if (solicitacao.ValorProposto.HasValue)
                            {
                                <div class="valor-proposto">R$ @solicitacao.ValorProposto.Value.ToString("N2")</div>
                            }
                            @if (solicitacao.DataResposta.HasValue)
                            {
                                <small class="text-muted">Respondido em @solicitacao.DataResposta.Value.ToString("dd/MM/yyyy HH:mm")</small>
                            }
                            <div class="mt-2">
                                <form method="post" asp-action="AceitarOrcamento" style="display: inline;">
                                    <input type="hidden" name="solicitacaoId" value="@solicitacao.Id" />
                                    <button type="submit" class="btn-aceitar">
                                        <i class="fas fa-check"></i> Aceitar Orçamento
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-file-invoice d-block"></i>
                <h4 style="color: #999; font-weight: 600;">Nenhuma solicitação enviada</h4>
                <p class="text-muted">Explore o marketplace e solicite orçamentos dos fornecedores.</p>
                <a asp-action="Index" class="btn-marketplace" style="display: inline-block;">
                    <i class="fas fa-store"></i> Ir ao Marketplace
                </a>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function filtrarStatus(status) {
            document.querySelectorAll('.tab-filtro').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');

            document.querySelectorAll('.solicitacao-card').forEach(card => {
                if (!status || card.dataset.status === status) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
}
