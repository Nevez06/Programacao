@model IEnumerable<ProjetoEventX.Models.Pedido>
@{
    ViewData["Title"] = "Pedidos";
}

@{
    var tipoUsuario = (string?)ViewBag.TipoUsuario ?? "";
    var isFornecedor = tipoUsuario == "Fornecedor";
    var isOrganizador = tipoUsuario == "Organizador";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="text-eventx-primary">
                <i class="fas fa-shopping-cart"></i> Pedidos
                @if (ViewBag.EventoNome != null)
                {
                    <small class="text-muted">- @ViewBag.EventoNome</small>
                }
            </h1>
            <p class="text-muted">
                @if (isFornecedor)
                {
                    @:Gerencie os pedidos recebidos para seus produtos
                }
                else
                {
                    @:Acompanhe os pedidos dos seus eventos
                }
            </p>
        </div>
        <div class="col-md-4 text-end">
            @if (isOrganizador && ViewBag.EventoId != null)
            {
                <a asp-action="Create" asp-route-eventoId="@ViewBag.EventoId" class="btn btn-eventx-primary">
                    <i class="fas fa-plus"></i> Novo Pedido
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <!-- Resumo -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card card-eventx text-center p-3">
                    <h4 class="mb-1">@Model.Count()</h4>
                    <small class="text-muted">Total de Pedidos</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-eventx text-center p-3">
                    <h4 class="mb-1">@Model.Count(p => p.StatusPedido == "Pendente")</h4>
                    <small class="text-muted">Pendentes</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-eventx text-center p-3">
                    <h4 class="mb-1">@Model.Count(p => p.StatusPedido == "Pago" || p.StatusPedido == "Entregue")</h4>
                    <small class="text-muted">Confirmados</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-eventx text-center p-3">
                    <h4 class="mb-1 text-success">R$ @Model.Sum(p => p.PrecoTotal).ToString("N2")</h4>
                    <small class="text-muted">Valor Total</small>
                </div>
            </div>
        </div>

        <!-- Tabela de Pedidos -->
        <div class="card card-eventx">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Evento</th>
                                <th>Qtd</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Data</th>
                                @if (isFornecedor)
                                {
                                    <th>Organizador</th>
                                    <th>Ações</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@pedido.Produto?.Nome</strong>
                                    </td>
                                    <td>@pedido.Evento?.NomeEvento</td>
                                    <td>@pedido.Quantidade</td>
                                    <td><strong>R$ @pedido.PrecoTotal.ToString("N2")</strong></td>
                                    <td>
                                        @{
                                            var badgeClass = pedido.StatusPedido switch
                                            {
                                                "Pendente" => "bg-warning text-dark",
                                                "Pago" => "bg-info text-white",
                                                "Entregue" => "bg-success",
                                                "Cancelado" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@pedido.StatusPedido</span>
                                    </td>
                                    <td>@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                                    @if (isFornecedor)
                                    {
                                        <td>@(pedido.Evento?.NomeEvento ?? "—")</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-outline-primary btn-sm" title="Detalhes">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (pedido.StatusPedido == "Pendente")
                                                {
                                                    <form asp-action="AtualizarStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@pedido.Id" />
                                                        <input type="hidden" name="novoStatus" value="Pago" />
                                                        <button type="submit" class="btn btn-outline-success btn-sm" title="Confirmar Pedido">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="Cancelar" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@pedido.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Recusar Pedido"
                                                                onclick="return confirm('Tem certeza que deseja recusar este pedido?')">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                }
                                                @if (pedido.StatusPedido == "Pago")
                                                {
                                                    <form asp-action="AtualizarStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@pedido.Id" />
                                                        <input type="hidden" name="novoStatus" value="Entregue" />
                                                        <button type="submit" class="btn btn-outline-info btn-sm" title="Marcar como Entregue">
                                                            <i class="fas fa-truck"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <div class="mb-3">
                <i class="fas fa-shopping-cart fa-3x text-muted"></i>
            </div>
            <h4 class="text-muted">Nenhum pedido encontrado</h4>
            <p class="text-muted">Comece criando um pedido para o seu evento.</p>
            @if (ViewBag.EventoId != null)
            {
                <a asp-action="Create" asp-route-eventoId="@ViewBag.EventoId" class="btn btn-eventx-primary mt-2">
                    <i class="fas fa-plus"></i> Criar Primeiro Pedido
                </a>
            }
            else
            {
                <a asp-controller="Eventos" asp-action="Index" class="btn btn-eventx-primary mt-2">
                    <i class="fas fa-calendar-alt"></i> Ver Meus Eventos
                </a>
            }
        </div>
    }

    <div class="mt-3">
        @if (isFornecedor)
        {
            <a asp-controller="Fornecedor" asp-action="Dashboard" class="btn btn-eventx-secondary">
                <i class="fas fa-arrow-left"></i> Voltar ao Dashboard
            </a>
        }
        else if (ViewBag.EventoId != null)
        {
            <a asp-controller="Organizador" asp-action="DetalhesEvento" asp-route-id="@ViewBag.EventoId" class="btn btn-eventx-secondary">
                <i class="fas fa-arrow-left"></i> Voltar ao Evento
            </a>
        }
        else
        {
            <a asp-controller="Organizador" asp-action="Dashboard" class="btn btn-eventx-secondary">
                <i class="fas fa-arrow-left"></i> Voltar ao Dashboard
            </a>
        }
    </div>
</div>
