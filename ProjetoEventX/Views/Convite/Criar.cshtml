@model ProjetoEventX.Models.ListaConvidado
@{
    ViewData["Title"] = "Criar Convite";
    var templates = ViewBag.Templates as List<ProjetoEventX.Models.TemplateConvite> ?? new List<ProjetoEventX.Models.TemplateConvite>();
}

<style>
    /* ===== CONVITE PAGE STYLES ===== */
    .convite-page {
        background: #f5f1ed;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

    /* Header */
    .convite-hero {
        background: linear-gradient(135deg, #8B0000 0%, #B22222 40%, #D4A574 100%);
        color: #fff;
        padding: 2.5rem 0;
        margin-bottom: 2rem;
    }

    .convite-hero h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .convite-hero p {
        opacity: 0.85;
        font-size: 1rem;
        margin: 0;
    }

    .hero-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    /* Event info bar */
    .event-info-bar {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .event-info-bar .info-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: #555;
    }

    .event-info-bar .info-item i {
        color: #8B0000;
        font-size: 1rem;
    }

    .event-info-bar .info-item strong {
        color: #333;
    }

    /* Cards */
    .convite-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        padding: 1.8rem;
        margin-bottom: 1.5rem;
        transition: box-shadow 0.2s;
    }

    .convite-card:hover {
        box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    }

    .convite-card h5 {
        font-weight: 700;
        color: #8B0000;
        margin-bottom: 1.3rem;
        font-size: 1.05rem;
        padding-bottom: 0.8rem;
        border-bottom: 2px solid #f0ece8;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Form fields */
    .convite-card .form-label {
        font-weight: 600;
        color: #444;
        font-size: 0.88rem;
        margin-bottom: 0.4rem;
    }

    .convite-card .form-label i {
        color: #8B0000;
        margin-right: 0.3rem;
    }

    .convite-card .form-control,
    .convite-card .form-select {
        border: 2px solid #e8e4e0;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .convite-card .form-control:focus,
    .convite-card .form-select:focus {
        border-color: #8B0000;
        box-shadow: 0 0 0 3px rgba(139,0,0,0.1);
    }

    .convite-card textarea.form-control {
        resize: vertical;
        min-height: 90px;
    }

    .convite-card .form-text {
        font-size: 0.78rem;
        color: #999;
    }

    /* Buttons */
    .btn-enviar {
        background: linear-gradient(135deg, #8B0000, #B22222);
        color: #fff;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-enviar:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(139,0,0,0.3);
        color: #fff;
    }

    .btn-rascunho {
        background: #fff;
        color: #8B0000;
        border: 2px solid #8B0000;
        padding: 0.7rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-rascunho:hover {
        background: #fdf0f0;
        color: #6B0000;
    }

    .btn-cancelar {
        background: #f0ece8;
        color: #555;
        border: none;
        padding: 0.7rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-cancelar:hover {
        background: #e5e0db;
        color: #333;
    }

    /* Template cards */
    .template-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .template-option {
        background: #faf8f6;
        border: 2px solid #e8e4e0;
        border-radius: 14px;
        padding: 1.2rem 1rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s;
        position: relative;
    }

    .template-option:hover {
        border-color: #B22222;
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(139,0,0,0.12);
    }

    .template-option.active {
        border-color: #8B0000;
        background: linear-gradient(135deg, #fff5f5, #fff);
        box-shadow: 0 4px 16px rgba(139,0,0,0.15);
    }

    .template-option.active::after {
        content: '\f058';
        font-family: 'Font Awesome 6 Free', 'Font Awesome 5 Free';
        font-weight: 900;
        position: absolute;
        top: 8px;
        right: 8px;
        color: #8B0000;
        font-size: 1.1rem;
    }

    .template-option .template-emoji {
        font-size: 2.2rem;
        display: block;
        margin-bottom: 0.5rem;
    }

    .template-option .template-name {
        font-size: 0.82rem;
        font-weight: 600;
        color: #444;
    }

    /* Custom template button */
    .template-option.custom-new {
        border-style: dashed;
        background: transparent;
    }

    .template-option.custom-new .template-emoji {
        color: #8B0000;
        opacity: 0.7;
    }

    /* Saved templates */
    .saved-template-card {
        background: #faf8f6;
        border: 2px solid #e8e4e0;
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .saved-template-card:hover {
        border-color: #B22222;
        background: #fff;
    }

    .saved-template-card.active {
        border-color: #8B0000;
        background: #fff5f5;
    }

    .saved-template-card .st-color {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        flex-shrink: 0;
    }

    .saved-template-card .st-info {
        flex: 1;
        min-width: 0;
    }

    .saved-template-card .st-name {
        font-weight: 600;
        font-size: 0.88rem;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .saved-template-card .st-meta {
        font-size: 0.75rem;
        color: #999;
    }

    .saved-template-card .st-badge {
        background: #8B0000;
        color: #fff;
        font-size: 0.65rem;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 600;
    }

    /* Editor Panel */
    .editor-section {
        background: #faf8f6;
        border-radius: 12px;
        padding: 1.2rem;
        margin-bottom: 1rem;
    }

    .editor-section label {
        font-weight: 600;
        font-size: 0.82rem;
        color: #555;
        margin-bottom: 0.3rem;
        display: block;
    }

    .color-picker-group {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .color-picker-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
    }

    .color-picker-item input[type="color"] {
        width: 44px;
        height: 44px;
        border: 2px solid #e0dcd8;
        border-radius: 10px;
        cursor: pointer;
        padding: 2px;
        background: #fff;
    }

    .color-picker-item span {
        font-size: 0.72rem;
        color: #777;
        font-weight: 500;
    }

    .font-selector {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
    }

    .font-selector .form-select {
        font-size: 0.85rem;
        padding: 0.5rem 0.7rem;
        border: 2px solid #e0dcd8;
        border-radius: 8px;
    }

    /* Preview */
    .preview-container {
        background: #e8e4e0;
        border-radius: 14px;
        padding: 1.5rem;
        min-height: 380px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .preview-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        transition: all 0.3s;
    }

    .preview-header {
        padding: 2rem 1.5rem 1.2rem;
        text-align: center;
        color: #fff;
        background: linear-gradient(135deg, #8B0000, #B22222);
    }

    .preview-header h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .preview-header p {
        opacity: 0.85;
        font-size: 0.88rem;
        margin: 0;
    }

    .preview-body {
        padding: 1.5rem;
    }

    .preview-body .greeting {
        font-size: 1rem;
        color: #333;
        margin-bottom: 0.8rem;
    }

    .preview-body .message {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.6;
        margin-bottom: 1.2rem;
    }

    .preview-details {
        background: #faf8f6;
        border-radius: 10px;
        padding: 1rem;
        margin-bottom: 1.2rem;
    }

    .preview-details .detail-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.35rem 0;
        font-size: 0.85rem;
        color: #555;
    }

    .preview-details .detail-row i {
        color: #8B0000;
        width: 18px;
        text-align: center;
    }

    .preview-btn {
        display: block;
        text-align: center;
        padding: 0.8rem 2rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        color: #fff;
        background: linear-gradient(135deg, #8B0000, #B22222);
        transition: all 0.2s;
    }

    .preview-footer {
        padding: 1rem 1.5rem;
        text-align: center;
        font-size: 0.75rem;
        color: #999;
        border-top: 1px solid #f0ece8;
    }

    /* Alerts */
    .alert-sucesso {
        background: #E8F5E9;
        color: #2E7D32;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    .alert-erro {
        background: #FFEBEE;
        color: #C62828;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    .alert-info-custom {
        background: #E3F2FD;
        color: #1565C0;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    /* Tabs */
    .editor-tabs {
        display: flex;
        gap: 0;
        background: #f0ece8;
        border-radius: 10px;
        padding: 4px;
        margin-bottom: 1.2rem;
    }

    .editor-tab {
        flex: 1;
        padding: 0.6rem 1rem;
        text-align: center;
        font-size: 0.82rem;
        font-weight: 600;
        color: #777;
        border: none;
        background: transparent;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .editor-tab.active {
        background: #fff;
        color: #8B0000;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .editor-tab:hover:not(.active) {
        color: #555;
    }

    .tab-content-panel {
        display: none;
    }

    .tab-content-panel.active {
        display: block;
    }

    /* Responsive */
    @@media (max-width: 991px) {
        .template-grid {
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }
    }

    @@media (max-width: 767px) {
        .convite-hero h1 { font-size: 1.4rem; }
        .event-info-bar { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
        .convite-card { padding: 1.2rem; }
        .template-grid { grid-template-columns: repeat(2, 1fr); }
        .preview-container { padding: 1rem; }
    }
</style>

<div class="convite-page">
    <!-- ===== HEADER ===== -->
    <section class="convite-hero">
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="hero-icon">
                    <i class="fas fa-envelope-open-text"></i>
                </div>
                <div>
                    <h1>Central de Convites</h1>
                    <p>Crie e personalize convites para <strong>@ViewBag.NomeEvento</strong></p>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Alerts -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-erro mb-3"><i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-sucesso mb-3"><i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert-info-custom mb-3"><i class="fas fa-info-circle me-2"></i>@TempData["InfoMessage"]</div>
        }

        <!-- Event Info Bar -->
        <div class="event-info-bar">
            <div class="info-item">
                <i class="fas fa-calendar-alt"></i>
                <span><strong>@ViewBag.NomeEvento</strong></span>
            </div>
            <div class="info-item">
                <i class="fas fa-clock"></i>
                <span>@ViewBag.DataEvento &bull; @ViewBag.HoraInicio - @ViewBag.HoraFim</span>
            </div>
            <div class="info-item">
                <i class="fas fa-map-marker-alt"></i>
                <span>@ViewBag.NomeLocal</span>
            </div>
            <div class="info-item">
                <i class="fas fa-tag"></i>
                <span>@ViewBag.TipoEvento</span>
            </div>
        </div>

        <!-- ===== MAIN LAYOUT ===== -->
        <div class="row">
            <!-- LEFT COLUMN: Form + Templates -->
            <div class="col-lg-5">
                <form asp-action="Criar" method="post" id="conviteForm">
                    <input type="hidden" name="eventoId" value="@ViewBag.EventoId" />
                    <input type="hidden" name="templateId" id="templateIdHidden" value="" />
                    <div asp-validation-summary="ModelOnly" class="alert-erro mb-3"></div>

                    <!-- Configuração do Convite -->
                    <div class="convite-card">
                        <h5><i class="fas fa-user-plus"></i> Dados do Convidado</h5>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-user"></i> Nome do Convidado
                            </label>
                            <input type="text" name="Convidado.Pessoa.Nome" id="nomeConvidado" class="form-control" placeholder="Digite o nome completo" required />
                            <small class="form-text">Nome que aparecerá no convite</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-envelope"></i> Email do Convidado
                            </label>
                            <input type="email" name="Convidado.Pessoa.Email" id="emailConvidado" class="form-control" placeholder="email@exemplo.com" required />
                            <small class="form-text">O convite será enviado para este email</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-comment-dots"></i> Mensagem Personalizada <span class="text-muted" style="font-weight:400;">(opcional)</span>
                            </label>
                            <textarea name="mensagemPersonalizada" id="mensagemPersonalizada" class="form-control" rows="3" placeholder="Escreva uma mensagem especial para o convidado..."></textarea>
                            <small class="form-text">Será incluída no corpo do convite</small>
                        </div>
                    </div>

                    <!-- Template Selection -->
                    <div class="convite-card">
                        <h5><i class="fas fa-palette"></i> Escolha um Template</h5>

                        <div class="template-grid" id="templateGrid">
                            <div class="template-option active" data-template="festa" onclick="selecionarTemplate(this, 'festa')">
                                <span class="template-emoji">🎉</span>
                                <span class="template-name">Festa</span>
                            </div>
                            <div class="template-option" data-template="casamento" onclick="selecionarTemplate(this, 'casamento')">
                                <span class="template-emoji">💍</span>
                                <span class="template-name">Casamento</span>
                            </div>
                            <div class="template-option" data-template="formatura" onclick="selecionarTemplate(this, 'formatura')">
                                <span class="template-emoji">🎓</span>
                                <span class="template-name">Formatura</span>
                            </div>
                            <div class="template-option" data-template="corporativo" onclick="selecionarTemplate(this, 'corporativo')">
                                <span class="template-emoji">🏢</span>
                                <span class="template-name">Corporativo</span>
                            </div>
                            <div class="template-option" data-template="show" onclick="selecionarTemplate(this, 'show')">
                                <span class="template-emoji">🎶</span>
                                <span class="template-name">Show / Festa</span>
                            </div>
                            <div class="template-option" data-template="aniversario" onclick="selecionarTemplate(this, 'aniversario')">
                                <span class="template-emoji">🎂</span>
                                <span class="template-name">Aniversário</span>
                            </div>
                        </div>

                        @if (templates.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-size:0.82rem; color:#888;">
                                    <i class="fas fa-bookmark"></i> Seus Templates Salvos
                                </label>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var tpl in templates)
                                    {
                                        <div class="saved-template-card" data-saved-id="@tpl.Id" onclick="selecionarTemplateSalvo(this, @tpl.Id)">
                                            <div class="st-color" style="background: @tpl.CorPrimaria;"></div>
                                            <div class="st-info">
                                                <div class="st-name">@tpl.NomeTemplate</div>
                                                <div class="st-meta">@tpl.EstiloLayout &bull; Criado em @tpl.CreatedAt.ToString("dd/MM")</div>
                                            </div>
                                            @if (tpl.PadraoSistema)
                                            {
                                                <span class="st-badge">Padrão</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <a asp-controller="TemplateConvite" asp-action="Create" asp-route-eventoId="@ViewBag.EventoId" class="template-option custom-new d-flex align-items-center justify-content-center gap-2" style="display:flex!important; text-decoration:none; width:100%;">
                            <span class="template-emoji" style="font-size:1.4rem;">✨</span>
                            <span class="template-name">Criar meu próprio convite</span>
                        </a>
                    </div>

                    <!-- Action Buttons -->
                    <div class="convite-card">
                        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
                            <a asp-controller="Organizador" asp-action="DetalhesEvento" asp-route-id="@ViewBag.EventoId" class="btn-cancelar">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn-rascunho" onclick="salvarRascunho()">
                                    <i class="fas fa-save"></i> Salvar Rascunho
                                </button>
                                <button type="submit" class="btn-enviar">
                                    <i class="fas fa-paper-plane"></i> Enviar Convite
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- RIGHT COLUMN: Editor + Preview -->
            <div class="col-lg-7">
                <!-- Editor Tabs -->
                <div class="convite-card">
                    <h5><i class="fas fa-magic"></i> Personalizar &amp; Visualizar</h5>

                    <div class="editor-tabs">
                        <button class="editor-tab active" onclick="switchTab('personalizar', this)">
                            <i class="fas fa-sliders-h me-1"></i> Personalizar
                        </button>
                        <button class="editor-tab" onclick="switchTab('preview', this)">
                            <i class="fas fa-eye me-1"></i> Preview
                        </button>
                        <button class="editor-tab" onclick="switchTab('exportar', this)">
                            <i class="fas fa-share-alt me-1"></i> Exportar
                        </button>
                    </div>

                    <!-- TAB: Personalizar -->
                    <div id="tab-personalizar" class="tab-content-panel active">
                        <!-- Cores -->
                        <div class="editor-section">
                            <label><i class="fas fa-fill-drip me-1"></i> Cores</label>
                            <div class="color-picker-group mt-2">
                                <div class="color-picker-item">
                                    <input type="color" id="corFundo" value="#ffffff" onchange="atualizarPreview()" />
                                    <span>Fundo</span>
                                </div>
                                <div class="color-picker-item">
                                    <input type="color" id="corPrimaria" value="#8B0000" onchange="atualizarPreview()" />
                                    <span>Primária</span>
                                </div>
                                <div class="color-picker-item">
                                    <input type="color" id="corTexto" value="#333333" onchange="atualizarPreview()" />
                                    <span>Texto</span>
                                </div>
                                <div class="color-picker-item">
                                    <input type="color" id="corBotao" value="#8B0000" onchange="atualizarPreview()" />
                                    <span>Botão</span>
                                </div>
                            </div>
                        </div>

                        <!-- Fontes -->
                        <div class="editor-section">
                            <label><i class="fas fa-font me-1"></i> Tipografia</label>
                            <div class="font-selector mt-2">
                                <select id="fonteTitulo" class="form-select" onchange="atualizarPreview()">
                                    <option value="'Inter', sans-serif">Inter (Padrão)</option>
                                    <option value="'Georgia', serif">Georgia</option>
                                    <option value="'Playfair Display', serif">Playfair Display</option>
                                    <option value="'Montserrat', sans-serif">Montserrat</option>
                                    <option value="'Roboto', sans-serif">Roboto</option>
                                    <option value="'Dancing Script', cursive">Dancing Script</option>
                                </select>
                                <select id="fonteTexto" class="form-select" onchange="atualizarPreview()">
                                    <option value="'Inter', sans-serif">Inter (Padrão)</option>
                                    <option value="'Georgia', serif">Georgia</option>
                                    <option value="'Open Sans', sans-serif">Open Sans</option>
                                    <option value="'Lato', sans-serif">Lato</option>
                                    <option value="'Roboto', sans-serif">Roboto</option>
                                </select>
                            </div>
                            <small class="form-text">Fonte do título (esq.) e do corpo (dir.)</small>
                        </div>

                        <!-- Título e Mensagem -->
                        <div class="editor-section">
                            <label><i class="fas fa-heading me-1"></i> Conteúdo do Convite</label>
                            <input type="text" id="tituloConvite" class="form-control mt-2 mb-2" value="Você está convidado!" placeholder="Título do convite" oninput="atualizarPreview()" />
                            <textarea id="mensagemConvite" class="form-control" rows="3" placeholder="Mensagem principal do convite..." oninput="atualizarPreview()">Será uma honra contar com a sua presença neste evento especial.</textarea>
                        </div>

                        <!-- Elementos -->
                        <div class="editor-section">
                            <label><i class="fas fa-puzzle-piece me-1"></i> Elementos Visuais</label>
                            <div class="mt-2 d-flex flex-wrap gap-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="mostrarLogo" checked onchange="atualizarPreview()">
                                    <label class="form-check-label" for="mostrarLogo" style="font-size:0.85rem;">Logo EventX</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="mostrarLocal" checked onchange="atualizarPreview()">
                                    <label class="form-check-label" for="mostrarLocal" style="font-size:0.85rem;">Detalhes do Local</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="mostrarEmoji" checked onchange="atualizarPreview()">
                                    <label class="form-check-label" for="mostrarEmoji" style="font-size:0.85rem;">Emojis</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Preview -->
                    <div id="tab-preview" class="tab-content-panel">
                        <!-- Preview is always visible below, this tab just scrolls to it -->
                        <p class="text-center text-muted" style="font-size:0.9rem;"><i class="fas fa-arrow-down me-1"></i> Visualize o convite abaixo em tempo real</p>
                    </div>

                    <!-- TAB: Exportar -->
                    <div id="tab-exportar" class="tab-content-panel">
                        <div class="editor-section">
                            <label><i class="fas fa-download me-1"></i> Exportar Convite</label>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                <button type="button" class="btn-rascunho" onclick="exportarConvite('png')">
                                    <i class="fas fa-image"></i> Exportar como PNG
                                </button>
                                <button type="button" class="btn-rascunho" onclick="exportarConvite('pdf')">
                                    <i class="fas fa-file-pdf"></i> Exportar como PDF
                                </button>
                            </div>
                        </div>
                        <div class="editor-section">
                            <label><i class="fas fa-link me-1"></i> Compartilhar via Link</label>
                            <div class="d-flex gap-2 mt-2">
                                <input type="text" id="linkCompartilhar" class="form-control" value="@(Context.Request.Scheme)://@(Context.Request.Host)/Convite/ConfirmarPresenca?eventoId=@ViewBag.EventoId&convidadoId=0" readonly style="font-size:0.85rem;" />
                                <button type="button" class="btn-rascunho" onclick="copiarLink()" style="white-space:nowrap;">
                                    <i class="fas fa-copy"></i> Copiar
                                </button>
                            </div>
                            <small class="form-text">O link será gerado após enviar o convite</small>
                        </div>
                    </div>
                </div>

                <!-- Live Preview -->
                <div class="convite-card">
                    <h5><i class="fas fa-eye"></i> Preview em Tempo Real</h5>
                    <div class="preview-container" id="previewContainer">
                        <div class="preview-card" id="previewCard">
                            <div class="preview-header" id="previewHeader">
                                <div id="previewLogo" style="margin-bottom:0.6rem;">
                                    <i class="fas fa-calendar-check" style="font-size:2rem; opacity:0.9;"></i>
                                </div>
                                <h2 id="previewTitulo">Você está convidado!</h2>
                                <p id="previewSubtitulo">@ViewBag.NomeEvento</p>
                            </div>
                            <div class="preview-body" id="previewBody">
                                <p class="greeting" id="previewSaudacao">
                                    <span id="previewEmoji">✨</span> Olá <strong id="previewNome">Convidado</strong>,
                                </p>
                                <p class="message" id="previewMensagem">
                                    Será uma honra contar com a sua presença neste evento especial.
                                </p>
                                <div class="preview-details" id="previewDetalhes">
                                    <div class="detail-row">
                                        <i class="fas fa-calendar-day"></i>
                                        <span><strong>Data:</strong> @ViewBag.DataEvento</span>
                                    </div>
                                    <div class="detail-row">
                                        <i class="fas fa-clock"></i>
                                        <span><strong>Horário:</strong> @ViewBag.HoraInicio - @ViewBag.HoraFim</span>
                                    </div>
                                    <div class="detail-row" id="previewLocalRow">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span><strong>Local:</strong> @ViewBag.NomeLocal</span>
                                    </div>
                                    <div class="detail-row" id="previewEnderecoRow">
                                        <i class="fas fa-road"></i>
                                        <span><strong>Endereço:</strong> @ViewBag.EnderecoLocal</span>
                                    </div>
                                </div>
                                <div id="previewMensagemExtra" style="display:none; margin-bottom:1.2rem;">
                                    <p style="font-style:italic; color:#666; font-size:0.88rem; background:#fdf8f5; padding:0.8rem; border-radius:8px; border-left:3px solid #8B0000;" id="previewMsgPersonalizada"></p>
                                </div>
                                <a class="preview-btn" id="previewBotao">
                                    Confirmar Presença
                                </a>
                            </div>
                            <div class="preview-footer">
                                Organizado com <i class="fas fa-heart" style="color:#8B0000;"></i> pelo EventX
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@400;700&family=Lato:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

    <script>
        // ===== Template Presets =====
        const templatePresets = {
            festa: {
                corPrimaria: '#E91E63',
                corFundo: '#ffffff',
                corTexto: '#333333',
                corBotao: '#E91E63',
                titulo: 'Você está convidado! 🎉',
                mensagem: 'Prepare-se para uma noite incrível! Venha celebrar conosco com muita alegria e diversão.',
                emoji: '🎉'
            },
            casamento: {
                corPrimaria: '#8B6914',
                corFundo: '#fffdf7',
                corTexto: '#4a4a4a',
                corBotao: '#8B6914',
                titulo: 'Convite Especial 💍',
                mensagem: 'Com grande alegria, convidamos você para celebrar este momento único conosco. Sua presença tornará este dia ainda mais especial.',
                emoji: '💍'
            },
            formatura: {
                corPrimaria: '#1565C0',
                corFundo: '#ffffff',
                corTexto: '#333333',
                corBotao: '#1565C0',
                titulo: 'Celebre Conosco! 🎓',
                mensagem: 'É com orgulho que convidamos você para a nossa cerimônia de formatura. Venha comemorar essa conquista conosco!',
                emoji: '🎓'
            },
            corporativo: {
                corPrimaria: '#37474F',
                corFundo: '#ffffff',
                corTexto: '#333333',
                corBotao: '#37474F',
                titulo: 'Convite Oficial',
                mensagem: 'Temos o prazer de convidá-lo para este evento corporativo. Será uma excelente oportunidade de networking e aprendizado.',
                emoji: '🏢'
            },
            show: {
                corPrimaria: '#7B1FA2',
                corFundo: '#1a1a2e',
                corTexto: '#ffffff',
                corBotao: '#E040FB',
                titulo: 'Você está na lista! 🎶',
                mensagem: 'O palco está pronto, a energia está no ar! Venha curtir uma noite inesquecível com música e muita diversão.',
                emoji: '🎶'
            },
            aniversario: {
                corPrimaria: '#FF6F00',
                corFundo: '#fff8f0',
                corTexto: '#333333',
                corBotao: '#FF6F00',
                titulo: 'Venha Comemorar! 🎂',
                mensagem: 'A festa está quase começando e não seria a mesma sem você! Venha soprar as velinhas conosco.',
                emoji: '🎂'
            }
        };

        let templateAtual = 'festa';

        // ===== Template Selection =====
        function selecionarTemplate(el, tipo) {
            document.querySelectorAll('.template-option').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.saved-template-card').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            templateAtual = tipo;
            document.getElementById('templateIdHidden').value = '';

            const preset = templatePresets[tipo];
            if (preset) {
                document.getElementById('corPrimaria').value = preset.corPrimaria;
                document.getElementById('corFundo').value = preset.corFundo;
                document.getElementById('corTexto').value = preset.corTexto;
                document.getElementById('corBotao').value = preset.corBotao;
                document.getElementById('tituloConvite').value = preset.titulo;
                document.getElementById('mensagemConvite').value = preset.mensagem;
            }
            atualizarPreview();
        }

        function selecionarTemplateSalvo(el, id) {
            document.querySelectorAll('.template-option').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.saved-template-card').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('templateIdHidden').value = id;
            atualizarPreview();
        }

        // ===== Live Preview Update =====
        function atualizarPreview() {
            const corPrimaria = document.getElementById('corPrimaria').value;
            const corFundo = document.getElementById('corFundo').value;
            const corTexto = document.getElementById('corTexto').value;
            const corBotao = document.getElementById('corBotao').value;
            const fonteTitulo = document.getElementById('fonteTitulo').value;
            const fonteTexto = document.getElementById('fonteTexto').value;
            const titulo = document.getElementById('tituloConvite').value;
            const mensagem = document.getElementById('mensagemConvite').value;
            const nome = document.getElementById('nomeConvidado').value || 'Convidado';
            const msgPessoal = document.getElementById('mensagemPersonalizada').value;
            const mostrarLogo = document.getElementById('mostrarLogo').checked;
            const mostrarLocal = document.getElementById('mostrarLocal').checked;
            const mostrarEmoji = document.getElementById('mostrarEmoji').checked;

            // Header
            const header = document.getElementById('previewHeader');
            header.style.background = `linear-gradient(135deg, ${corPrimaria}, ${ajustarCor(corPrimaria, 30)})`;

            // Body
            const card = document.getElementById('previewCard');
            card.style.background = corFundo;

            const body = document.getElementById('previewBody');
            body.style.color = corTexto;
            body.style.fontFamily = fonteTexto;

            // Title
            document.getElementById('previewTitulo').textContent = titulo;
            document.getElementById('previewTitulo').style.fontFamily = fonteTitulo;

            // Message
            document.getElementById('previewMensagem').textContent = mensagem;

            // Name
            document.getElementById('previewNome').textContent = nome;

            // Button
            const btn = document.getElementById('previewBotao');
            btn.style.background = `linear-gradient(135deg, ${corBotao}, ${ajustarCor(corBotao, 20)})`;

            // Logo
            document.getElementById('previewLogo').style.display = mostrarLogo ? 'block' : 'none';

            // Local
            document.getElementById('previewLocalRow').style.display = mostrarLocal ? 'flex' : 'none';
            document.getElementById('previewEnderecoRow').style.display = mostrarLocal ? 'flex' : 'none';

            // Emoji
            const emojiEl = document.getElementById('previewEmoji');
            if (mostrarEmoji) {
                const preset = templatePresets[templateAtual];
                emojiEl.textContent = preset ? preset.emoji : '✨';
                emojiEl.style.display = 'inline';
            } else {
                emojiEl.style.display = 'none';
            }

            // Personal message
            const msgExtra = document.getElementById('previewMensagemExtra');
            const msgExtraText = document.getElementById('previewMsgPersonalizada');
            if (msgPessoal && msgPessoal.trim().length > 0) {
                msgExtra.style.display = 'block';
                msgExtraText.textContent = '"' + msgPessoal + '"';
                msgExtraText.style.borderLeftColor = corPrimaria;
            } else {
                msgExtra.style.display = 'none';
            }
        }

        // Lighten/darken a hex color
        function ajustarCor(hex, amount) {
            let r = parseInt(hex.slice(1, 3), 16);
            let g = parseInt(hex.slice(3, 5), 16);
            let b = parseInt(hex.slice(5, 7), 16);
            r = Math.min(255, r + amount);
            g = Math.min(255, g + amount);
            b = Math.min(255, b + amount);
            return '#' + [r, g, b].map(x => x.toString(16).padStart(2, '0')).join('');
        }

        // ===== Tabs =====
        function switchTab(tab, btn) {
            document.querySelectorAll('.editor-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content-panel').forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('tab-' + tab).classList.add('active');

            if (tab === 'preview') {
                document.getElementById('previewContainer').scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        // ===== Draft =====
        function salvarRascunho() {
            const dados = {
                nome: document.getElementById('nomeConvidado').value,
                email: document.getElementById('emailConvidado').value,
                mensagem: document.getElementById('mensagemPersonalizada').value,
                template: templateAtual,
                corPrimaria: document.getElementById('corPrimaria').value,
                corFundo: document.getElementById('corFundo').value,
                corTexto: document.getElementById('corTexto').value,
                corBotao: document.getElementById('corBotao').value,
                titulo: document.getElementById('tituloConvite').value,
                mensagemConvite: document.getElementById('mensagemConvite').value
            };
            localStorage.setItem('rascunho_convite_@ViewBag.EventoId', JSON.stringify(dados));

            const toast = document.createElement('div');
            toast.className = 'alert-sucesso';
            toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;padding:1rem 1.5rem;box-shadow:0 4px 20px rgba(0,0,0,0.15);animation:fadeInDown 0.3s;';
            toast.innerHTML = '<i class="fas fa-check-circle me-2"></i>Rascunho salvo com sucesso!';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function carregarRascunho() {
            const dados = localStorage.getItem('rascunho_convite_@ViewBag.EventoId');
            if (dados) {
                try {
                    const d = JSON.parse(dados);
                    if (d.nome) document.getElementById('nomeConvidado').value = d.nome;
                    if (d.email) document.getElementById('emailConvidado').value = d.email;
                    if (d.mensagem) document.getElementById('mensagemPersonalizada').value = d.mensagem;
                    if (d.corPrimaria) document.getElementById('corPrimaria').value = d.corPrimaria;
                    if (d.corFundo) document.getElementById('corFundo').value = d.corFundo;
                    if (d.corTexto) document.getElementById('corTexto').value = d.corTexto;
                    if (d.corBotao) document.getElementById('corBotao').value = d.corBotao;
                    if (d.titulo) document.getElementById('tituloConvite').value = d.titulo;
                    if (d.mensagemConvite) document.getElementById('mensagemConvite').value = d.mensagemConvite;
                    if (d.template && templatePresets[d.template]) {
                        const el = document.querySelector(`[data-template="${d.template}"]`);
                        if (el) {
                            document.querySelectorAll('.template-option').forEach(t => t.classList.remove('active'));
                            el.classList.add('active');
                            templateAtual = d.template;
                        }
                    }
                    atualizarPreview();
                } catch(e) {}
            }
        }

        // ===== Export =====
        function exportarConvite(formato) {
            const previewCard = document.getElementById('previewCard');
            if (formato === 'png') {
                // Use html2canvas if available, otherwise simple fallback
                if (typeof html2canvas !== 'undefined') {
                    html2canvas(previewCard, { scale: 2, useCORS: true }).then(canvas => {
                        const link = document.createElement('a');
                        link.download = 'convite-@(ViewBag.NomeEvento).png';
                        link.href = canvas.toDataURL('image/png');
                        link.click();
                    });
                } else {
                    alert('Funcionalidade de exportação PNG será disponibilizada em breve. Use Print (Ctrl+P) como alternativa.');
                }
            } else if (formato === 'pdf') {
                window.print();
            }
        }

        // ===== Copy Link =====
        function copiarLink() {
            const input = document.getElementById('linkCompartilhar');
            input.select();
            document.execCommand('copy');

            const toast = document.createElement('div');
            toast.className = 'alert-info-custom';
            toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;padding:1rem 1.5rem;box-shadow:0 4px 20px rgba(0,0,0,0.15);';
            toast.innerHTML = '<i class="fas fa-check me-2"></i>Link copiado!';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
        }

        // ===== Init =====
        document.addEventListener('DOMContentLoaded', function() {
            // Bind live preview on name/email/message fields
            document.getElementById('nomeConvidado').addEventListener('input', atualizarPreview);
            document.getElementById('emailConvidado').addEventListener('input', atualizarPreview);
            document.getElementById('mensagemPersonalizada').addEventListener('input', atualizarPreview);

            // Load draft if exists
            carregarRascunho();

            // Initial preview
            atualizarPreview();

            // Clear draft on successful submit
            document.getElementById('conviteForm').addEventListener('submit', function() {
                localStorage.removeItem('rascunho_convite_@ViewBag.EventoId');
            });
        });
    </script>
}
