@model ProjetoEventX.Models.Produto
@{
    ViewData["Title"] = "Detalhes do Produto - " + Model.Nome;
}

<style>
    .detalhes-section {
        background: var(--eventx-secondary, #f5f0eb);
        min-height: 80vh;
        padding: 3rem 0;
    }

    .voltar-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--eventx-primary, #8B0000);
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 2rem;
        transition: all 0.3s;
    }

    .voltar-btn:hover {
        color: var(--eventx-primary-dark, #654321);
        transform: translateX(-5px);
    }

    .produto-detalhes-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .produto-header {
        background: linear-gradient(135deg, var(--eventx-primary, #8B0000), var(--eventx-accent, #D4A574));
        color: #fff;
        padding: 2.5rem;
        text-align: center;
    }

    .produto-header .produto-icon {
        width: 90px;
        height: 90px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        font-size: 2.5rem;
    }

    .produto-header h2 {
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .produto-header .tipo-badge {
        display: inline-block;
        background: rgba(255,255,255,0.25);
        padding: 5px 18px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .produto-body {
        padding: 2.5rem;
    }

    .produto-info-row {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .produto-info-item {
        flex: 1;
        min-width: 200px;
    }

    .produto-info-item label {
        display: block;
        font-size: 0.85rem;
        color: #999;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .produto-info-item .valor {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
    }

    .produto-preco-destaque {
        font-size: 2rem;
        font-weight: 700;
        color: var(--eventx-primary, #8B0000);
    }

    .produto-descricao-completa {
        color: #555;
        line-height: 1.7;
        font-size: 1rem;
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 10px;
        margin-bottom: 2rem;
    }

    .divider {
        border: none;
        border-top: 2px solid #f0f0f0;
        margin: 2rem 0;
    }

    .fornecedor-section-title {
        color: var(--eventx-primary, #8B0000);
        font-weight: 700;
        font-size: 1.4rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .fornecedor-section-title i {
        font-size: 1.2rem;
    }

    .fornecedor-card {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 2rem;
        border-left: 4px solid var(--eventx-primary, #8B0000);
    }

    .fornecedor-card .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0.7rem 0;
        border-bottom: 1px solid #eee;
    }

    .fornecedor-card .info-item:last-child {
        border-bottom: none;
    }

    .fornecedor-card .info-item i {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--eventx-primary, #8B0000);
        color: #fff;
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .fornecedor-card .info-item .info-label {
        font-size: 0.8rem;
        color: #999;
        display: block;
    }

    .fornecedor-card .info-item .info-value {
        font-weight: 600;
        color: #333;
        font-size: 1rem;
    }

    /* Botão de Realizar Pedido */
    .btn-realizar-pedido {
        background: linear-gradient(135deg, #8B0000, #B22222);
        color: #fff;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(139, 0, 0, 0.3);
    }

    .btn-realizar-pedido:hover {
        background: linear-gradient(135deg, #6B0000, #8B0000);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 0, 0, 0.4);
        color: #fff;
    }

    .pedido-section {
        background: linear-gradient(135deg, #f8f4f0, #fff);
        border: 2px solid #8B0000;
        border-radius: 15px;
        padding: 2rem;
        text-align: center;
        margin-top: 2rem;
    }

    .pedido-section h4 {
        color: #8B0000;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .pedido-section p {
        color: #666;
        margin-bottom: 1.5rem;
    }

    .modal-pedido .modal-header {
        background: linear-gradient(135deg, #8B0000, #B22222);
        color: #fff;
    }

    .modal-pedido .produto-resumo {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1.2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .modal-pedido .produto-resumo .produto-icon-mini {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #8B0000, #D4A574);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .modal-pedido .produto-resumo .nome-prod {
        font-weight: 700;
        color: #333;
    }

    .modal-pedido .produto-resumo .preco-prod {
        color: #8B0000;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .preco-total-display {
        background: #f0ebe5;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        margin-top: 1rem;
    }

    .preco-total-display .label {
        font-size: 0.8rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .preco-total-display .valor-total {
        font-size: 1.8rem;
        font-weight: 700;
        color: #8B0000;
    }
</style>

<section class="detalhes-section">
    <div class="container">
        <a asp-action="Catalogo" class="voltar-btn">
            <i class="fas fa-arrow-left"></i> Voltar ao Catálogo
        </a>

        <div class="produto-detalhes-card">
            <!-- Header do Produto -->
            <div class="produto-header">
                <div class="produto-icon">
                    <i class="fas fa-box"></i>
                </div>
                <h2>@Model.Nome</h2>
                <span class="tipo-badge">@Model.Tipo</span>
            </div>

            <!-- Body -->
            <div class="produto-body">
                <div class="produto-info-row">
                    <div class="produto-info-item">
                        <label>Preço</label>
                        <span class="produto-preco-destaque">R$ @Model.Preco.ToString("N2")</span>
                    </div>
                    <div class="produto-info-item">
                        <label>Tipo</label>
                        <span class="valor">@Model.Tipo</span>
                    </div>
                </div>

                <label style="font-size: 0.85rem; color: #999; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block;">Descrição</label>
                <div class="produto-descricao-completa">
                    @Model.Descricao
                </div>

                <hr class="divider" />

                <!-- Informações do Fornecedor -->
                <h4 class="fornecedor-section-title">
                    <i class="fas fa-store"></i> Informações do Fornecedor
                </h4>

                <div class="fornecedor-card">
                    <div class="info-item">
                        <i class="fas fa-store"></i>
                        <div>
                            <span class="info-label">Nome da Loja</span>
                            <span class="info-value">@(Model.Fornecedor?.Pessoa?.Nome ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-id-card"></i>
                        <div>
                            <span class="info-label">CNPJ</span>
                            <span class="info-value">@(Model.Fornecedor?.Cnpj ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <span class="info-label">Telefone</span>
                            <span class="info-value">@(Model.Fornecedor?.PhoneNumber ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <span class="info-label">Email</span>
                            <span class="info-value">@(Model.Fornecedor?.Email ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <span class="info-label">Localização</span>
                            <span class="info-value">@(Model.Fornecedor?.Cidade ?? "")/​@(Model.Fornecedor?.UF ?? "")</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-concierge-bell"></i>
                        <div>
                            <span class="info-label">Tipo de Serviço</span>
                            <span class="info-value">@(Model.Fornecedor?.TipoServico ?? "Não informado")</span>
                        </div>
                    </div>
                </div>

                @if (ViewBag.IsOrganizador == true)
                {
                    var eventos = ViewBag.EventosOrganizador as List<ProjetoEventX.Models.Evento>;
                    <div class="pedido-section">
                        <h4><i class="fas fa-shopping-cart me-2"></i>Interessado neste produto?</h4>
                        <p>Realize um pedido e o fornecedor será notificado do seu interesse.</p>
                        @if (eventos != null && eventos.Any())
                        {
                            <button type="button" class="btn-realizar-pedido" data-bs-toggle="modal" data-bs-target="#realizarPedidoModal">
                                <i class="fas fa-cart-plus"></i> Realizar Pedido
                            </button>
                        }
                        else
                        {
                            <div class="alert" style="background: #FFF3E0; color: #E65100; border-radius: 10px; display: inline-block; padding: 12px 24px;">
                                <i class="fas fa-info-circle me-2"></i>Crie um evento primeiro para poder realizar pedidos.
                                <br />
                                <a asp-controller="Organizador" asp-action="CriarEvento" class="mt-2 d-inline-block" style="color: #8B0000; font-weight: 600;">
                                    <i class="fas fa-plus-circle me-1"></i>Criar Evento
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@if (ViewBag.IsOrganizador == true)
{
    var eventosModal = ViewBag.EventosOrganizador as List<ProjetoEventX.Models.Evento>;
    if (eventosModal != null && eventosModal.Any())
    {
        <!-- Modal Realizar Pedido -->
        <div class="modal fade modal-pedido" id="realizarPedidoModal" tabindex="-1" aria-labelledby="realizarPedidoModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="realizarPedidoModalLabel">
                            <i class="fas fa-cart-plus me-2"></i>Realizar Pedido
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Resumo do Produto -->
                        <div class="produto-resumo">
                            <div class="produto-icon-mini">
                                <i class="fas fa-box"></i>
                            </div>
                            <div>
                                <div class="nome-prod">@Model.Nome</div>
                                <div class="preco-prod">R$ @Model.Preco.ToString("N2") <small style="color:#999; font-weight: 400;">/ unidade</small></div>
                            </div>
                        </div>

                        <form asp-controller="Pedido" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="produtoId" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-calendar-alt me-1 text-muted"></i> Selecione o Evento</label>
                                <select name="eventoId" class="form-control" required>
                                    <option value="">-- Escolha um evento --</option>
                                    @foreach (var evento in eventosModal)
                                    {
                                        <option value="@evento.Id">@evento.NomeEvento — @evento.DataEvento.ToString("dd/MM/yyyy")</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-sort-numeric-up me-1 text-muted"></i> Quantidade</label>
                                <input type="number" name="quantidade" id="quantidadePedido" class="form-control" value="1" min="1" required />
                            </div>

                            <div class="preco-total-display">
                                <div class="label">Total Estimado</div>
                                <div class="valor-total" id="totalEstimado">R$ @Model.Preco.ToString("N2")</div>
                            </div>

                            <div class="d-grid mt-3">
                                <button type="submit" class="btn-realizar-pedido" style="justify-content: center; width: 100%;">
                                    <i class="fas fa-check-circle"></i> Confirmar Pedido
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var precoUnitario = @Model.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var quantidadeInput = document.getElementById('quantidadePedido');
                var totalDisplay = document.getElementById('totalEstimado');

                quantidadeInput.addEventListener('input', function () {
                    var qtd = parseInt(this.value) || 1;
                    if (qtd < 1) qtd = 1;
                    var total = (precoUnitario * qtd).toFixed(2).replace('.', ',');
                    totalDisplay.textContent = 'R$ ' + total;
                });
            });
        </script>
    }
}
