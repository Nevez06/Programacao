@model ProjetoEventX.Models.Organizador
@{
    ViewData["Title"] = "Meu Perfil";
    var totalEventos = (int)(ViewBag.TotalEventos ?? 0);
    var eventosAtivos = (int)(ViewBag.EventosAtivos ?? 0);
    var eventosConcluidos = (int)(ViewBag.EventosConcluidos ?? 0);
    var totalConvidados = (int)(ViewBag.TotalConvidados ?? 0);
    var totalGasto = (decimal)(ViewBag.TotalGasto ?? 0m);
}

<style>
    .perfil-wrapper {
        background: #f5f1ed;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

    .perfil-header {
        background: linear-gradient(135deg, #8B0000 0%, #B22222 50%, #D4A574 100%);
        color: #fff;
        padding: 3rem 0 5rem;
        position: relative;
    }

    .perfil-avatar {
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        border: 4px solid rgba(255,255,255,0.4);
    }

    .perfil-nome {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .perfil-email {
        opacity: 0.85;
        font-size: 1rem;
    }

    .perfil-badge {
        background: rgba(255,255,255,0.2);
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin-top: 0.5rem;
    }

    /* Cards Info */
    .perfil-content {
        margin-top: -3rem;
        position: relative;
        z-index: 1;
    }

    .info-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        margin-bottom: 1.5rem;
    }

    .info-card h5 {
        font-weight: 700;
        color: #333;
        margin-bottom: 1.2rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-card h5 i {
        color: #8B0000;
    }

    .info-row {
        display: flex;
        align-items: center;
        padding: 0.8rem 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 36px;
        height: 36px;
        background: #FFF3E0;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1rem;
        color: #8B0000;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 0.8rem;
        color: #999;
        display: block;
    }

    .info-value {
        font-weight: 600;
        color: #333;
        font-size: 0.95rem;
    }

    /* Estatísticas mini */
    .stat-mini {
        text-align: center;
        padding: 1rem;
    }

    .stat-mini-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #8B0000;
        line-height: 1;
    }

    .stat-mini-label {
        font-size: 0.75rem;
        color: #888;
        margin-top: 4px;
    }

    /* Formulário */
    .form-control-perfil {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        transition: border-color 0.3s ease;
    }

    .form-control-perfil:focus {
        border-color: #8B0000;
        box-shadow: 0 0 0 0.2rem rgba(139, 0, 0, 0.1);
    }

    .form-label-perfil {
        font-weight: 600;
        color: #555;
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    /* Alertas */
    .alert-sucesso {
        background: #E8F5E9;
        border: 1px solid #A5D6A7;
        color: #2E7D32;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    .alert-erro {
        background: #FFEBEE;
        border: 1px solid #EF9A9A;
        color: #C62828;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

    .btn-salvar {
        background: #8B0000;
        color: #fff;
        border: none;
        padding: 0.6rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-salvar:hover {
        background: #6B0000;
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(139, 0, 0, 0.3);
    }

    .btn-cancelar {
        background: #D4C5B9;
        color: #8B0000;
        border: 1px solid #8B0000;
        padding: 0.6rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-cancelar:hover {
        background: #c4b5a9;
        color: #6B0000;
    }

    .section-divider {
        border: none;
        border-top: 2px solid #f0ebe5;
        margin: 1.5rem 0;
    }

    .senha-toggle {
        background: none;
        border: none;
        color: #8B0000;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        padding: 0;
        transition: color 0.3s;
    }

    .senha-toggle:hover {
        color: #6B0000;
    }
</style>

<div class="perfil-wrapper">
    <!-- Header do Perfil -->
    <section class="perfil-header">
        <div class="container">
            <div class="d-flex align-items-center gap-3">
                <div class="perfil-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <div class="perfil-nome">@(Model.Pessoa?.Nome ?? Model.UserName)</div>
                    <div class="perfil-email">@(Model.Email ?? "—")</div>
                    <span class="perfil-badge"><i class="fas fa-crown me-1"></i> Organizador</span>
                </div>
            </div>
        </div>
    </section>

    <div class="container perfil-content">
        <!-- Alertas -->
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert-sucesso mb-3">
                <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert-erro mb-3">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Erro"]
            </div>
        }

        <div class="row g-4">
            <!-- Coluna Esquerda -->
            <div class="col-lg-8">
                <!-- Informações Pessoais -->
                <div class="info-card">
                    <h5><i class="fas fa-user-circle"></i> Informações Pessoais</h5>

                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-user"></i></div>
                        <div>
                            <span class="info-label">Nome Completo</span>
                            <span class="info-value">@(Model.Pessoa?.Nome ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-envelope"></i></div>
                        <div>
                            <span class="info-label">Email</span>
                            <span class="info-value">@(Model.Email ?? "—")</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-phone"></i></div>
                        <div>
                            <span class="info-label">Telefone</span>
                            <span class="info-value">@(Model.Pessoa?.Telefone ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-id-card"></i></div>
                        <div>
                            <span class="info-label">CPF</span>
                            <span class="info-value">@(Model.Pessoa?.Cpf ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <span class="info-label">Endereço</span>
                            <span class="info-value">@(Model.Pessoa?.Endereco ?? "Não informado")</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-city"></i></div>
                        <div>
                            <span class="info-label">Cidade / UF</span>
                            <span class="info-value">
                                @(string.IsNullOrEmpty(Model.Pessoa?.Cidade) ? "Não informado" : $"{Model.Pessoa.Cidade}/{Model.Pessoa.UF}")
                            </span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-calendar-check"></i></div>
                        <div>
                            <span class="info-label">Membro desde</span>
                            <span class="info-value">@Model.DataCadastro.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>

                <!-- Editar Perfil -->
                <div class="info-card">
                    <h5><i class="fas fa-edit"></i> Editar Perfil</h5>

                    <form asp-action="Profile" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-perfil">Nome Completo</label>
                                <input type="text" name="nome" class="form-control form-control-perfil" value="@(Model.Pessoa?.Nome)" placeholder="Seu nome completo" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-perfil">Telefone</label>
                                <input type="text" name="telefone" class="form-control form-control-perfil" value="@(Model.Pessoa?.Telefone)" placeholder="(00) 00000-0000" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label-perfil">Endereço</label>
                                <input type="text" name="endereco" class="form-control form-control-perfil" value="@(Model.Pessoa?.Endereco)" placeholder="Rua, número, bairro" />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label-perfil">Cidade</label>
                                <input type="text" name="cidade" class="form-control form-control-perfil" value="@(Model.Pessoa?.Cidade)" placeholder="Sua cidade" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-perfil">UF</label>
                                <input type="text" name="uf" class="form-control form-control-perfil" value="@(Model.Pessoa?.UF)" maxlength="2" placeholder="SP" style="text-transform: uppercase;" />
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn-salvar"><i class="fas fa-save me-2"></i>Salvar Alterações</button>
                            <a asp-action="Profile" class="btn-cancelar text-decoration-none"><i class="fas fa-times me-2"></i>Cancelar</a>
                        </div>
                    </form>
                </div>

                <!-- Alterar Senha -->
                <div class="info-card">
                    <h5><i class="fas fa-lock"></i> Segurança</h5>

                    <div id="senhaSection">
                        <button class="senha-toggle" onclick="document.getElementById('formSenha').style.display = document.getElementById('formSenha').style.display === 'none' ? 'block' : 'none'">
                            <i class="fas fa-key me-1"></i> Alterar senha
                        </button>

                        <form asp-action="AlterarSenha" method="post" id="formSenha" style="display: none;" class="mt-3">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label-perfil">Senha Atual</label>
                                    <input type="password" name="senhaAtual" class="form-control form-control-perfil" required placeholder="Digite sua senha atual" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-perfil">Nova Senha</label>
                                    <input type="password" name="novaSenha" class="form-control form-control-perfil" required minlength="6" placeholder="Mínimo 6 caracteres" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-perfil">Confirmar Nova Senha</label>
                                    <input type="password" name="confirmarSenha" class="form-control form-control-perfil" required minlength="6" placeholder="Repita a nova senha" />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <button type="submit" class="btn-salvar"><i class="fas fa-lock me-2"></i>Alterar Senha</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Coluna Direita -->
            <div class="col-lg-4">
                <!-- Estatísticas -->
                <div class="info-card">
                    <h5><i class="fas fa-chart-pie"></i> Estatísticas</h5>
                    <div class="row g-0">
                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-mini-number">@totalEventos</div>
                                <div class="stat-mini-label">Eventos Criados</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-mini-number">@eventosAtivos</div>
                                <div class="stat-mini-label">Eventos Ativos</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-mini-number">@eventosConcluidos</div>
                                <div class="stat-mini-label">Concluídos</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-mini-number">@totalConvidados</div>
                                <div class="stat-mini-label">Convidados</div>
                            </div>
                        </div>
                    </div>
                    <hr class="section-divider">
                    <div class="text-center">
                        <div style="font-size: 0.8rem; color: #888;">Total em Despesas</div>
                        <div style="font-size: 1.4rem; font-weight: 700; color: #E65100;">R$ @totalGasto.ToString("N2")</div>
                    </div>
                </div>

                <!-- Ações Rápidas -->
                <div class="info-card">
                    <h5><i class="fas fa-bolt"></i> Ações Rápidas</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Dashboard" class="btn-salvar text-center text-decoration-none d-block">
                            <i class="fas fa-gauge me-2"></i>Dashboard
                        </a>
                        <a asp-action="MeusEventos" class="btn-cancelar text-center text-decoration-none d-block">
                            <i class="fas fa-calendar-alt me-2"></i>Meus Eventos
                        </a>
                        <a asp-action="Orcamento" class="btn-cancelar text-center text-decoration-none d-block">
                            <i class="fas fa-wallet me-2"></i>Orçamento
                        </a>
                    </div>
                </div>

                <!-- Conta -->
                <div class="info-card">
                    <h5><i class="fas fa-cog"></i> Conta</h5>
                    <div class="info-row">
                        <div class="info-icon" style="background: #E3F2FD; color: #1565C0;"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <span class="info-label">Tipo de Conta</span>
                            <span class="info-value">Organizador</span>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon" style="background: #E8F5E9; color: #2E7D32;"><i class="fas fa-check-circle"></i></div>
                        <div>
                            <span class="info-label">Status</span>
                            <span class="info-value" style="color: #2E7D32;">Ativo</span>
                        </div>
                    </div>
                    <hr class="section-divider">
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="btn w-100" style="background: #FFEBEE; color: #C62828; border: 1px solid #EF9A9A; border-radius: 8px; font-weight: 600; padding: 0.6rem;">
                            <i class="fas fa-sign-out-alt me-2"></i>Sair da Conta
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
