@model ProjetoEventX.Models.Organizador
@{
    ViewData["Title"] = "Dashboard - Organizador";
    Layout = "_Layout";
    var proximoEvento = ViewBag.ProximoEvento as ProjetoEventX.Models.Evento;
}

<style>
    .dash-wrapper {
        background: #f5f1ed;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

    /* Header de Boas-vindas */
    .dash-welcome {
        background: linear-gradient(135deg, #8B0000 0%, #B22222 50%, #D4A574 100%);
        color: #fff;
        padding: 2.5rem 0;
        margin-bottom: 2rem;
    }

    .dash-welcome h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .dash-welcome p {
        opacity: 0.85;
        font-size: 1rem;
        margin: 0;
    }

    .dash-welcome .user-avatar {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-right: 1rem;
    }

    /* Cards de Estatísticas */
    .stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .stat-icon.eventos { background: linear-gradient(135deg, #8B0000, #B22222); }
    .stat-icon.convidados { background: linear-gradient(135deg, #2E7D32, #43A047); }
    .stat-icon.orcamento { background: linear-gradient(135deg, #E65100, #FF8F00); }
    .stat-icon.concluidos { background: linear-gradient(135deg, #1565C0, #42A5F5); }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #333;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.85rem;
        color: #888;
        margin-top: 2px;
    }

    /* Próximo Evento */
    .next-event-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border-left: 5px solid #8B0000;
    }

    .next-event-card h5 {
        color: #8B0000;
        font-weight: 700;
    }

    .next-event-card .event-date {
        font-size: 0.9rem;
        color: #666;
    }

    .next-event-card .event-name {
        font-size: 1.3rem;
        font-weight: 700;
        color: #333;
        margin: 0.5rem 0;
    }

    .event-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .event-meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: #666;
    }

    .event-meta-item i {
        color: #8B0000;
    }

    /* Ações Rápidas */
    .quick-action {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .quick-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        color: inherit;
        text-decoration: none;
    }

    .quick-action .qa-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #8B0000, #D4A574);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.8rem;
        color: #fff;
        font-size: 1.4rem;
    }

    .quick-action h6 {
        font-weight: 700;
        color: #333;
        margin-bottom: 0.2rem;
    }

    .quick-action p {
        font-size: 0.8rem;
        color: #999;
        margin: 0;
    }

    /* Lista de Eventos */
    .eventos-list-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .eventos-list-card h5 {
        font-weight: 700;
        color: #333;
        margin-bottom: 1.2rem;
    }

    .evento-item {
        display: flex;
        align-items: center;
        padding: 1rem;
        border-radius: 12px;
        background: #f8f9fa;
        margin-bottom: 0.8rem;
        transition: background 0.2s;
    }

    .evento-item:hover {
        background: #f0ebe5;
    }

    .evento-item .evento-date-box {
        min-width: 55px;
        text-align: center;
        margin-right: 1rem;
    }

    .evento-date-box .day {
        font-size: 1.5rem;
        font-weight: 700;
        color: #8B0000;
        line-height: 1;
    }

    .evento-date-box .month {
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        font-weight: 600;
    }

    .evento-item .evento-info {
        flex: 1;
    }

    .evento-info .evento-nome {
        font-weight: 600;
        color: #333;
        font-size: 0.95rem;
    }

    .evento-info .evento-tipo {
        font-size: 0.8rem;
        color: #888;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-badge.planejado { background: #FFF3E0; color: #E65100; }
    .status-badge.andamento { background: #E3F2FD; color: #1565C0; }
    .status-badge.concluido { background: #E8F5E9; color: #2E7D32; }
    .status-badge.cancelado { background: #FFEBEE; color: #C62828; }

    .section-title {
        font-weight: 700;
        color: #333;
        margin-bottom: 1.2rem;
        font-size: 1.1rem;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: #999;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.3;
    }
</style>

<div class="dash-wrapper">
    <!-- Header de Boas-vindas -->
    <section class="dash-welcome">
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="user-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <h1>Olá, @(Model.Pessoa?.Nome ?? Model.UserName)!</h1>
                    <p>Gerencie seus eventos com praticidade e eficiência</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Cards de Estatísticas -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon eventos">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="stat-number">@ViewBag.TotalEventos</div>
                    <div class="stat-label">Total de Eventos</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon convidados">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-number">@ViewBag.TotalConvidados</div>
                    <div class="stat-label">Convidados (@ViewBag.ConvidadosConfirmados confirmados)</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon orcamento">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <div class="stat-number">R$ @(((decimal)ViewBag.TotalDespesas).ToString("N0"))</div>
                    <div class="stat-label">Total em Despesas</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon concluidos">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-number">@ViewBag.EventosConcluidos</div>
                    <div class="stat-label">Eventos Concluídos</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Coluna Esquerda -->
            <div class="col-lg-8">
                <!-- Próximo Evento -->
                @if (proximoEvento != null)
                {
                    <div class="next-event-card mb-4">
                        <h5><i class="fas fa-star me-2"></i>Próximo Evento</h5>
                        <div class="event-name">@proximoEvento.NomeEvento</div>
                        <div class="event-meta">
                            <div class="event-meta-item">
                                <i class="fas fa-calendar"></i>
                                @proximoEvento.DataEvento.ToString("dd/MM/yyyy")
                            </div>
                            <div class="event-meta-item">
                                <i class="fas fa-clock"></i>
                                @proximoEvento.HoraInicio - @proximoEvento.HoraFim
                            </div>
                            <div class="event-meta-item">
                                <i class="fas fa-tag"></i>
                                @proximoEvento.TipoEvento
                            </div>
                            <div class="event-meta-item">
                                <i class="fas fa-users"></i>
                                @proximoEvento.PublicoEstimado pessoas
                            </div>
                        </div>
                    </div>
                }

                <!-- Lista de Eventos -->
                <div class="eventos-list-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Meus Eventos</h5>
                        <a asp-action="CriarEvento" class="btn btn-sm" style="background: #8B0000; color: #fff;">
                            <i class="fas fa-plus"></i> Novo
                        </a>
                    </div>

                    @if (Model.Eventos != null && Model.Eventos.Any())
                    {
                        @foreach (var evento in Model.Eventos.OrderByDescending(e => e.DataEvento).Take(5))
                        {
                            <a asp-action="DetalhesEvento" asp-route-id="@evento.Id" style="text-decoration: none;">
                                <div class="evento-item">
                                    <div class="evento-date-box">
                                        <div class="day">@evento.DataEvento.Day</div>
                                        <div class="month">@evento.DataEvento.ToString("MMM")</div>
                                    </div>
                                    <div class="evento-info">
                                        <div class="evento-nome">@evento.NomeEvento</div>
                                        <div class="evento-tipo">@evento.TipoEvento · @evento.HoraInicio - @evento.HoraFim</div>
                                    </div>
                                    @{
                                        var statusClass = evento.StatusEvento?.ToLower() switch {
                                            "planejado" => "planejado",
                                            "em andamento" => "andamento",
                                            "concluído" or "finalizado" => "concluido",
                                            "cancelado" => "cancelado",
                                            _ => "planejado"
                                        };
                                    }
                                    <span class="status-badge @statusClass">@evento.StatusEvento</span>
                                </div>
                            </a>
                        }

                        @if (Model.Eventos.Count > 5)
                        {
                            <div class="text-center mt-3">
                                <a asp-action="MeusEventos" class="btn btn-outline-secondary btn-sm">Ver todos os eventos</a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-calendar-plus d-block"></i>
                            <p>Você ainda não tem eventos criados.</p>
                            <a asp-action="CriarEvento" class="btn btn-sm" style="background: #8B0000; color: #fff;">
                                <i class="fas fa-plus"></i> Criar Primeiro Evento
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Coluna Direita -->
            <div class="col-lg-4">
                <!-- Ações Rápidas -->
                <h6 class="section-title"><i class="fas fa-bolt me-2"></i>Ações Rápidas</h6>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <a asp-action="CriarEvento" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-calendar-plus"></i>
                            </div>
                            <h6>Criar Evento</h6>
                            <p>Novo evento</p>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Convite" asp-action="Index" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <h6>Convidar</h6>
                            <p>Enviar convites</p>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Fornecedor" asp-action="Catalogo" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-store"></i>
                            </div>
                            <h6>Fornecedores</h6>
                            <p>Ver catálogo</p>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Administracao" asp-action="Index" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-chart-bar"></i>
                            </div>
                            <h6>Orçamento</h6>
                            <p>Gerenciar</p>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="TemplateConvite" asp-action="Index" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-palette"></i>
                            </div>
                            <h6>Templates</h6>
                            <p>Convites</p>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="IA" asp-action="Index" class="quick-action">
                            <div class="qa-icon">
                                <i class="fas fa-robot"></i>
                            </div>
                            <h6>Assistente IA</h6>
                            <p>Ajuda inteligente</p>
                        </a>
                    </div>
                </div>

                <!-- Info do Perfil -->
                <div class="eventos-list-card">
                    <h5><i class="fas fa-user-circle me-2"></i>Meu Perfil</h5>
                    <div class="mt-3">
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-user text-muted me-2" style="width: 20px;"></i>
                            <small class="text-muted">Nome:</small>
                            <strong class="ms-2" style="font-size: 0.9rem;">@(Model.Pessoa?.Nome ?? "—")</strong>
                        </div>
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-envelope text-muted me-2" style="width: 20px;"></i>
                            <small class="text-muted">Email:</small>
                            <strong class="ms-2" style="font-size: 0.9rem;">@(Model.Email ?? "—")</strong>
                        </div>
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-phone text-muted me-2" style="width: 20px;"></i>
                            <small class="text-muted">Telefone:</small>
                            <strong class="ms-2" style="font-size: 0.9rem;">@(Model.Pessoa?.Telefone ?? "—")</strong>
                        </div>
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-map-marker-alt text-muted me-2" style="width: 20px;"></i>
                            <small class="text-muted">Cidade:</small>
                            <strong class="ms-2" style="font-size: 0.9rem;">@(Model.Pessoa?.Cidade ?? "—")/@(Model.Pessoa?.UF ?? "—")</strong>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="fas fa-calendar-check text-muted me-2" style="width: 20px;"></i>
                            <small class="text-muted">Membro desde:</small>
                            <strong class="ms-2" style="font-size: 0.9rem;">@Model.DataCadastro.ToString("MMM/yyyy")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BOTÃO FLUTUANTE CHAT IA -->
<div class="floating-ai-btn" onclick="window.location.href='@Url.Action("Index", "IA")'">
    <div class="ai-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 15C21 15.5 20.8 16 20.5 16.4L16.4 20.5C16 20.8 15.5 21 15 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3H19C20.1 3 21 3.9 21 5V15Z" fill="white"/>
            <circle cx="9" cy="9" r="1.5" fill="#4CAF50"/>
            <circle cx="15" cy="9" r="1.5" fill="#4CAF50"/>
        </svg>
    </div>
    <span>Chat IA</span>
</div>
