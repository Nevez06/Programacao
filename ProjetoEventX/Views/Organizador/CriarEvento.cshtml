@model ProjetoEventX.Models.Evento
@{
    ViewData["Title"] = "Criar Evento";
    var googleMapsApiKey = ViewBag.GoogleMapsApiKey as string ?? "";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-eventx mt-5">
                <div class="card-body">
                    <h2 class="mb-4" style="color: var(--eventx-primary);">Novo Evento</h2>
                    
                    <form asp-action="CriarEvento" method="post" id="formCriarEvento">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="NomeEvento" class="form-label">Nome do evento</label>
                                <input asp-for="NomeEvento" class="form-control" placeholder="Evento de Exemplo" />
                                <span asp-validation-for="NomeEvento" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataEvento" class="form-label">Data do evento</label>
                                <input asp-for="DataEvento" type="date" class="form-control" />
                                <span asp-validation-for="DataEvento" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="TipoEvento" class="form-label">Tipo de evento</label>
                                <input asp-for="TipoEvento" class="form-control" placeholder="Casamento, Aniversário, etc." />
                                <span asp-validation-for="TipoEvento" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="DescricaoEvento" class="form-label">Descrição</label>
                            <textarea asp-for="DescricaoEvento" class="form-control" rows="4" placeholder="Um evento especial para lembrar..."></textarea>
                            <span asp-validation-for="DescricaoEvento" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="HoraInicio" class="form-label">Hora de início</label>
                                <input asp-for="HoraInicio" type="time" class="form-control" />
                                <span asp-validation-for="HoraInicio" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="HoraFim" class="form-label">Hora de fim</label>
                                <input asp-for="HoraFim" type="time" class="form-control" />
                                <span asp-validation-for="HoraFim" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="PublicoEstimado" class="form-label">Público estimado</label>
                            <input asp-for="PublicoEstimado" type="number" class="form-control" min="1" />
                            <span asp-validation-for="PublicoEstimado" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Custo estimado (R$)</label>
                            <div style="position: relative;">
                                <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #666; font-weight: 600;">R$</span>
                                <input type="text" name="CustoEstimadoTexto" id="custoEstimadoTexto" class="form-control" 
                                       inputmode="decimal" placeholder="0,00" 
                                       style="padding-left: 40px;"
                                       value="@(Model?.CustoEstimado > 0 ? Model.CustoEstimado.ToString("N2", new System.Globalization.CultureInfo("pt-BR")) : "")" />
                            </div>
                        </div>

                        <!-- Local do Evento com Google Maps -->
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-map-marker-alt" style="color: #8B0000;"></i> Local do evento
                            </label>
                            <div style="position: relative;">
                                <input type="text" id="localBusca" class="form-control" 
                                       placeholder="Busque o endereço do evento..." 
                                       autocomplete="off"
                                       style="padding-left: 12px; padding-right: 40px;" />
                                <i class="fas fa-search" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #999;"></i>
                            </div>
                            <input type="hidden" name="LocalNome" id="localNome" />
                            <input type="hidden" name="LocalEndereco" id="localEndereco" />
                            
                            <!-- Info do local selecionado -->
                            <div id="localSelecionado" style="display: none; margin-top: 10px; padding: 12px 16px; background: linear-gradient(135deg, #f8f6f4 0%, #ede8e2 100%); border-radius: 10px; border-left: 4px solid #8B0000;">
                                <div style="display: flex; align-items: center; justify-content: space-between;">
                                    <div>
                                        <strong id="localNomeDisplay" style="color: #8B0000; font-size: 0.95rem;"></strong>
                                        <p id="localEnderecoDisplay" style="margin: 4px 0 0; color: #666; font-size: 0.85rem;"></p>
                                    </div>
                                    <button type="button" id="btnRemoverLocal" style="background: none; border: none; color: #999; font-size: 1.2rem; cursor: pointer;" title="Remover local">
                                        <i class="fas fa-times-circle"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Mapa preview -->
                            <div id="mapContainer" style="display: none; margin-top: 10px; border-radius: 10px; overflow: hidden; border: 2px solid #e0d6cc; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                                <div id="map" style="width: 100%; height: 250px;"></div>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn" style="background: #8B0000; color: #fff; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; border: none; transition: all 0.3s ease;">Criar Evento</button>
                            <a asp-action="Dashboard" class="btn" style="background: #D4C5B9; color: #8B0000; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; border: 1px solid #8B0000; transition: all 0.3s ease;">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    @if (!string.IsNullOrEmpty(googleMapsApiKey) && googleMapsApiKey != "USE_ENV_VARIABLE")
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&libraries=places&callback=initGoogleMaps" async defer></script>
    }

    <script>
        // ===== Máscara de valor para Custo Estimado =====
        (function() {
            var custoInput = document.getElementById('custoEstimadoTexto');
            if (custoInput) {
                custoInput.addEventListener('input', function(e) {
                    var val = this.value.replace(/[^0-9,\.]/g, '');
                    // Permitir apenas um separador decimal
                    var parts = val.split(/[,\.]/);
                    if (parts.length > 2) {
                        val = parts[0] + ',' + parts.slice(1).join('');
                    }
                    this.value = val;
                });
            }

            // Converter vírgula → ponto antes do submit
            var form = document.getElementById('formCriarEvento');
            if (form) {
                form.addEventListener('submit', function() {
                    if (custoInput && custoInput.value) {
                        custoInput.value = custoInput.value.replace(',', '.');
                    }
                });
            }
        })();

        // ===== Google Maps Places Autocomplete =====
        var map, marker, autocomplete;

        function initGoogleMaps() {
            // Inicializar mapa (centrado no Brasil)
            map = new google.maps.Map(document.getElementById('map'), {
                center: { lat: -15.7801, lng: -47.9292 },
                zoom: 4,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: false
            });

            marker = new google.maps.Marker({
                map: map,
                draggable: false
            });

            // Configurar Autocomplete
            var input = document.getElementById('localBusca');
            autocomplete = new google.maps.places.Autocomplete(input, {
                types: ['establishment', 'geocode'],
                componentRestrictions: { country: 'br' }
            });

            autocomplete.addListener('place_changed', function() {
                var place = autocomplete.getPlace();
                if (!place.geometry) return;

                // Preencher dados
                document.getElementById('localNome').value = place.name || '';
                document.getElementById('localEndereco').value = place.formatted_address || '';
                document.getElementById('localNomeDisplay').textContent = place.name || 'Local selecionado';
                document.getElementById('localEnderecoDisplay').textContent = place.formatted_address || '';

                // Mostrar info e mapa
                document.getElementById('localSelecionado').style.display = 'block';
                document.getElementById('mapContainer').style.display = 'block';

                // Centralizar mapa
                map.setCenter(place.geometry.location);
                map.setZoom(16);
                marker.setPosition(place.geometry.location);
                marker.setVisible(true);
            });
        }

        // Remover local selecionado
        document.getElementById('btnRemoverLocal').addEventListener('click', function() {
            document.getElementById('localNome').value = '';
            document.getElementById('localEndereco').value = '';
            document.getElementById('localBusca').value = '';
            document.getElementById('localSelecionado').style.display = 'none';
            document.getElementById('mapContainer').style.display = 'none';
            if (marker) marker.setVisible(false);
        });

        // Se não tem Google Maps API, usar busca manual
        @if (string.IsNullOrEmpty(googleMapsApiKey) || googleMapsApiKey == "USE_ENV_VARIABLE")
        {
            <text>
            (function() {
                var input = document.getElementById('localBusca');
                input.placeholder = 'Digite o endereço do evento...';
                
                input.addEventListener('change', function() {
                    if (this.value.trim()) {
                        document.getElementById('localNome').value = this.value.trim();
                        document.getElementById('localEndereco').value = this.value.trim();
                        document.getElementById('localNomeDisplay').textContent = this.value.trim();
                        document.getElementById('localEnderecoDisplay').textContent = this.value.trim();
                        document.getElementById('localSelecionado').style.display = 'block';
                        
                        // Mostrar mapa estático via embed (sem API key necessário)
                        var mapDiv = document.getElementById('map');
                        var query = encodeURIComponent(this.value.trim());
                        mapDiv.innerHTML = '<iframe width="100%" height="250" frameborder="0" style="border:0" ' +
                            'src="https://www.google.com/maps?q=' + query + '&output=embed" allowfullscreen></iframe>';
                        document.getElementById('mapContainer').style.display = 'block';
                    }
                });
            })();
            </text>
        }
    </script>
}



